@model wnc.Features.IdentityAccess.AuthLogs.AuthLogDetailsViewModel

@{
    ViewData["Title"] = "Auth Log Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Auth log details</h1>
        <p class="text-muted mb-0">@Model.LoginIdentifier</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">User</dt>
            <dd class="col-sm-9">@(Model.UserDisplay ?? "Anonymous / unknown")</dd>
            <dt class="col-sm-3">Login identifier</dt>
            <dd class="col-sm-9">@Model.LoginIdentifier</dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
            <dt class="col-sm-3">Failure reason</dt>
            <dd class="col-sm-9">@(Model.FailureReason ?? "-")</dd>
            <dt class="col-sm-3">IP address</dt>
            <dd class="col-sm-9">@(Model.IpAddress ?? "-")</dd>
            <dt class="col-sm-3">User agent</dt>
            <dd class="col-sm-9">@Model.UserAgent</dd>
            <dt class="col-sm-3">Logged at</dt>
            <dd class="col-sm-9">@Model.LoggedAt.ToString("g")</dd>
        </dl>
    </div>
</div>
