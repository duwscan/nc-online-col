@model wnc.Features.IdentityAccess.AuthLogs.AuthLogDetailsViewModel

@{
    ViewData["Title"] = "Delete Auth Log";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Delete auth log</h1>
        <p class="text-muted mb-0">This permanently removes the selected audit row.</p>
    </div>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Back to details</a>
</div>

<div class="card border-danger shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Login identifier</dt>
            <dd class="col-sm-9">@Model.LoginIdentifier</dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
            <dt class="col-sm-3">Logged at</dt>
            <dd class="col-sm-9">@Model.LoggedAt.ToString("g")</dd>
        </dl>
    </div>
    <div class="card-footer d-flex justify-content-end">
        <form asp-action="Delete" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger">Delete log</button>
        </form>
    </div>
</div>
