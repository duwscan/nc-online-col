@model wnc.Features.IdentityAccess.UserRoles.UserRolesIndexViewModel

@{
    ViewData["Title"] = "User Roles";

    string NextDirection(string sortBy) =>
        string.Equals(Model.Query.SortBy, sortBy, StringComparison.OrdinalIgnoreCase) && !Model.Query.IsDescending()
            ? "desc"
            : "asc";

    string SortIndicator(string sortBy)
    {
        if (!string.Equals(Model.Query.SortBy, sortBy, StringComparison.OrdinalIgnoreCase))
        {
            return string.Empty;
        }

        return Model.Query.IsDescending() ? "▼" : "▲";
    }

    Dictionary<string, string> SortRoute(string sortBy) => Model.Query.BuildRouteValues(sortBy, NextDirection(sortBy), 1);
    var userSortRoute = SortRoute("user");
    var roleSortRoute = SortRoute("role");
    var assignedBySortRoute = SortRoute("assignedBy");
    var assignedAtSortRoute = SortRoute("assignedAt");
    var revokedAtSortRoute = SortRoute("revokedAt");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">User roles</h1>
        <p class="text-muted mb-0">Manage user-to-role mappings with active/revoked state.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Create assignment</a>
</div>

<form method="get" class="card shadow-sm mb-4">
    <div class="card-body row g-3 align-items-end">
        <div class="col-lg-3">
            <label asp-for="Query.SearchTerm" class="form-label">Search</label>
            <input asp-for="Query.SearchTerm" class="form-control" placeholder="User, role or assigned by" />
        </div>
        <div class="col-lg-3">
            <label asp-for="Query.UserId" class="form-label">User</label>
            <select asp-for="Query.UserId" asp-items="Model.UserOptions" class="form-select"></select>
        </div>
        <div class="col-lg-3">
            <label asp-for="Query.RoleId" class="form-label">Role</label>
            <select asp-for="Query.RoleId" asp-items="Model.RoleOptions" class="form-select"></select>
        </div>
        <div class="col-lg-2">
            <label asp-for="Query.State" class="form-label">State</label>
            <select asp-for="Query.State" asp-items="Model.StateOptions" class="form-select">
                <option value="">All states</option>
            </select>
        </div>
        <div class="col-lg-1 d-grid">
            <button type="submit" class="btn btn-outline-primary">Apply</button>
        </div>
        <div class="col-lg-2">
            <label asp-for="Query.PageSize" class="form-label">Page size</label>
            <select asp-for="Query.PageSize" class="form-select">
                <option value="5">5</option>
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
            </select>
        </div>
    </div>
</form>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
            <tr>
                <th><a asp-action="Index" asp-all-route-data="userSortRoute" class="text-decoration-none">User @SortIndicator("user")</a></th>
                <th><a asp-action="Index" asp-all-route-data="roleSortRoute" class="text-decoration-none">Role @SortIndicator("role")</a></th>
                <th><a asp-action="Index" asp-all-route-data="assignedBySortRoute" class="text-decoration-none">Assigned by @SortIndicator("assignedBy")</a></th>
                <th><a asp-action="Index" asp-all-route-data="assignedAtSortRoute" class="text-decoration-none">Assigned at @SortIndicator("assignedAt")</a></th>
                <th><a asp-action="Index" asp-all-route-data="revokedAtSortRoute" class="text-decoration-none">Revoked at @SortIndicator("revokedAt")</a></th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            @if (Model.Result.Items.Count == 0)
            {
                <tr>
                    <td colspan="6" class="text-center py-4 text-muted">No assignments matched the current query.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model.Result.Items)
                {
                    <tr>
                        <td>@item.UserDisplay</td>
                        <td>@item.RoleDisplay</td>
                        <td>@(item.AssignedByDisplay ?? "-")</td>
                        <td>@item.AssignedAt.ToString("g")</td>
                        <td>@(item.RevokedAt?.ToString("g") ?? "Active")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center">
        <span class="text-muted">Showing @Model.Result.StartItem-@Model.Result.EndItem of @Model.Result.TotalCount</span>
        <div class="btn-group">
            <a asp-action="Index"
               asp-all-route-data="Model.Query.BuildRouteValues(page: Model.Result.Page - 1)"
               class="btn btn-outline-secondary @(Model.Result.HasPreviousPage ? string.Empty : "disabled")">Previous</a>
            <span class="btn btn-outline-secondary disabled">Page @Model.Result.Page / @Model.Result.TotalPages</span>
            <a asp-action="Index"
               asp-all-route-data="Model.Query.BuildRouteValues(page: Model.Result.Page + 1)"
               class="btn btn-outline-secondary @(Model.Result.HasNextPage ? string.Empty : "disabled")">Next</a>
        </div>
    </div>
</div>
