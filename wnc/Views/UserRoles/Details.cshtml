@model wnc.Features.IdentityAccess.UserRoles.UserRoleDetailsViewModel

@{
    ViewData["Title"] = "User Role Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">User role details</h1>
        <p class="text-muted mb-0">@Model.UserDisplay -> @Model.RoleDisplay</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">User</dt>
            <dd class="col-sm-9">@Model.UserDisplay</dd>
            <dt class="col-sm-3">Role</dt>
            <dd class="col-sm-9">@Model.RoleDisplay</dd>
            <dt class="col-sm-3">Assigned by</dt>
            <dd class="col-sm-9">@(Model.AssignedByDisplay ?? "-")</dd>
            <dt class="col-sm-3">Assigned at</dt>
            <dd class="col-sm-9">@Model.AssignedAt.ToString("g")</dd>
            <dt class="col-sm-3">Revoked at</dt>
            <dd class="col-sm-9">@(Model.RevokedAt?.ToString("g") ?? "-")</dd>
        </dl>
    </div>
</div>
