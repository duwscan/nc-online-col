@model StudentProfileViewModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
}

<div class="space-y-6">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
        <h1 class="mb-6 text-2xl font-semibold text-slate-900">Hồ sơ cá nhân</h1>

        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="mb-5 rounded-xl border border-green-200 bg-green-50 px-5 py-4 text-sm text-green-700">
                @Model.SuccessMessage
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="mb-5 rounded-xl border border-red-200 bg-red-50 px-5 py-4 text-sm text-red-700">
                @Model.ErrorMessage
            </div>
        }

        <form method="post" action="/student/profile" class="space-y-5">
            @Html.AntiForgeryToken()

            <div class="grid gap-5 sm:grid-cols-2">
                <div class="sm:col-span-2">
                    <label asp-for="FullName" class="mb-1 block text-sm font-medium text-slate-700"></label>
                    <input asp-for="FullName" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base text-slate-900" />
                    <span asp-validation-for="FullName" class="text-sm text-rose-600"></span>
                </div>

                <div>
                    <label asp-for="DateOfBirth" class="mb-1 block text-sm font-medium text-slate-700"></label>
                    <input asp-for="DateOfBirth" type="date" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base text-slate-900" />
                    <span asp-validation-for="DateOfBirth" class="text-sm text-rose-600"></span>
                </div>

                <div>
                    <label asp-for="Gender" class="mb-1 block text-sm font-medium text-slate-700"></label>
                    <select asp-for="Gender" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base text-slate-900">
                        <option value="">-- Chọn giới tính --</option>
                        <option value="Male">Nam</option>
                        <option value="Female">Nữ</option>
                        <option value="Other">Khác</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-sm text-rose-600"></span>
                </div>

                <div>
                    <label asp-for="NationalId" class="mb-1 block text-sm font-medium text-slate-700"></label>
                    <input asp-for="NationalId" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base text-slate-900" />
                    <span asp-validation-for="NationalId" class="text-sm text-rose-600"></span>
                </div>

                <div>
                    <label asp-for="Email" class="mb-1 block text-sm font-medium text-slate-700"></label>
                    <input asp-for="Email" type="email" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base text-slate-900" />
                    <span asp-validation-for="Email" class="text-sm text-rose-600"></span>
                </div>

                <div>
                    <label asp-for="PhoneNumber" class="mb-1 block text-sm font-medium text-slate-700"></label>
                    <input asp-for="PhoneNumber" type="tel" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base text-slate-900" />
                    <span asp-validation-for="PhoneNumber" class="text-sm text-rose-600"></span>
                </div>

                <div class="sm:col-span-2">
                    <label asp-for="AddressLine" class="mb-1 block text-sm font-medium text-slate-700"></label>
                    <input asp-for="AddressLine" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base text-slate-900" />
                    <span asp-validation-for="AddressLine" class="text-sm text-rose-600"></span>
                </div>

                <div>
                    <label asp-for="Ward" class="mb-1 block text-sm font-medium text-slate-700"></label>
                    <input asp-for="Ward" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base text-slate-900" />
                    <span asp-validation-for="Ward" class="text-sm text-rose-600"></span>
                </div>

                <div>
                    <label asp-for="District" class="mb-1 block text-sm font-medium text-slate-700"></label>
                    <input asp-for="District" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base text-slate-900" />
                    <span asp-validation-for="District" class="text-sm text-rose-600"></span>
                </div>

                <div>
                    <label asp-for="ProvinceCode" class="mb-1 block text-sm font-medium text-slate-700"></label>
                    <input asp-for="ProvinceCode" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base text-slate-900" />
                    <span asp-validation-for="ProvinceCode" class="text-sm text-rose-600"></span>
                </div>
            </div>

            <div class="flex items-center gap-4 pt-4">
                <button type="submit" class="rounded-xl bg-blue-600 px-6 py-3 text-sm font-semibold text-white hover:bg-blue-700">
                    Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
