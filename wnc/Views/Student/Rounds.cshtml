@model RoundsViewModel
@{
    ViewData["Title"] = "Đợt xét tuyển";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
}

<div class="space-y-6">
    <div>
        <h1 class="text-2xl font-semibold text-slate-900">Đợt xét tuyển</h1>
        <p class="mt-1 text-sm text-slate-500">Danh sách các đợt xét tuyển</p>
    </div>

    @if (Model.ActiveRounds.Count == 0 && Model.UpcomingRounds.Count == 0)
    {
        <div class="rounded-2xl border border-slate-200 bg-white p-12 text-center">
            <p class="text-slate-500">Hiện không có đợt xét tuyển nào</p>
        </div>
    }
    else
    {
        @if (Model.ActiveRounds.Count > 0)
        {
            <div>
                <h2 class="mb-3 text-lg font-medium text-slate-700">Đang mở</h2>
                <div class="space-y-4">
                    @foreach (var round in Model.ActiveRounds)
                    {
                        <div class="rounded-2xl border border-green-200 bg-white p-6 shadow-sm">
                            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                                <div>
                                    <h3 class="text-lg font-semibold text-slate-900">@round.RoundName</h3>
                                    <p class="text-sm text-slate-500">@round.RoundCode · Năm @round.AdmissionYear</p>
                                </div>
                                <span class="rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-700">Đang mở</span>
                            </div>

                            <div class="mt-4 flex flex-wrap gap-4 text-sm text-slate-600">
                                <div>
                                    <span class="font-medium">Thời gian:</span>
                                    <span>@round.StartAt.ToString("dd/MM/yyyy") - @round.EndAt.ToString("dd/MM/yyyy")</span>
                                </div>
                            </div>

                            @if (round.RoundPrograms.Any())
                            {
                                <div class="mt-5 border-t border-slate-100 pt-5">
                                    <h3 class="mb-3 text-sm font-medium text-slate-700">Ngành/Chương trình</h3>
                                    <div class="grid gap-3 sm:grid-cols-2">
                                        @foreach (var rp in round.RoundPrograms.Where(x => x.Status == "ACTIVE"))
                                        {
                                            <a href="/student/programs/@rp.Id" class="block rounded-xl border border-slate-100 bg-slate-50 p-4 transition-colors hover:border-blue-200 hover:bg-blue-50">
                                                <div class="font-medium text-slate-900">@rp.Program.ProgramName</div>
                                                @if (rp.Major != null)
                                                {
                                                    <div class="text-sm text-slate-600">@rp.Major.MajorName</div>
                                                }
                                                <div class="mt-2 flex flex-wrap gap-3 text-xs text-slate-500">
                                                    @if (rp.PublishedQuota.HasValue)
                                                    {
                                                        <span>Chỉ tiêu: @rp.PublishedQuota</span>
                                                    }
                                                    @if (rp.Program.TuitionFee.HasValue)
                                                    {
                                                        <span>Học phí: @rp.Program.TuitionFee.Value.ToString("N0")đ/năm</span>
                                                    }
                                                </div>
                                                @if (rp.AdmissionMethods.Any(x => x.Method != null))
                                                {
                                                    <div class="mt-2 flex flex-wrap gap-2">
                                                        @foreach (var method in rp.AdmissionMethods.Where(x => x.Method != null))
                                                        {
                                                            <span class="rounded-full bg-blue-50 px-2 py-0.5 text-xs text-blue-700">@method.Method.MethodName</span>
                                                        }
                                                    </div>
                                                }
                                            </a>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        @if (Model.UpcomingRounds.Count > 0)
        {
            <div>
                <h2 class="mb-3 text-lg font-medium text-slate-700">Sắp mở</h2>
                <div class="space-y-4">
                    @foreach (var round in Model.UpcomingRounds)
                    {
                        <div class="rounded-2xl border border-slate-200 bg-white p-6 opacity-75">
                            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                                <div>
                                    <h3 class="text-lg font-semibold text-slate-900">@round.RoundName</h3>
                                    <p class="text-sm text-slate-500">@round.RoundCode · Năm @round.AdmissionYear</p>
                                </div>
                                <span class="rounded-full bg-blue-100 px-3 py-1 text-xs font-medium text-blue-700">Sắp mở</span>
                            </div>

                            <div class="mt-4 flex flex-wrap gap-4 text-sm text-slate-600">
                                <div>
                                    <span class="font-medium">Thời gian:</span>
                                    <span>@round.StartAt.ToString("dd/MM/yyyy") - @round.EndAt.ToString("dd/MM/yyyy")</span>
                                </div>
                            </div>

                            @if (round.RoundPrograms.Any())
                            {
                                <div class="mt-5 border-t border-slate-100 pt-5">
                                    <h3 class="mb-3 text-sm font-medium text-slate-700">Ngành/Chương trình</h3>
                                    <div class="grid gap-3 sm:grid-cols-2">
                                        @foreach (var rp in round.RoundPrograms.Where(x => x.Status == "ACTIVE"))
                                        {
                                            <a href="/student/programs/@rp.Id" class="block rounded-xl border border-slate-100 bg-slate-50 p-4 transition-colors hover:border-blue-200 hover:bg-blue-50">
                                                <div class="font-medium text-slate-900">@rp.Program.ProgramName</div>
                                                @if (rp.Major != null)
                                                {
                                                    <div class="text-sm text-slate-600">@rp.Major.MajorName</div>
                                                }
                                                <div class="mt-2 flex flex-wrap gap-3 text-xs text-slate-500">
                                                    @if (rp.PublishedQuota.HasValue)
                                                    {
                                                        <span>Chỉ tiêu: @rp.PublishedQuota</span>
                                                    }
                                                </div>
                                            </a>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>
