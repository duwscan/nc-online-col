@model wnc.Features.Students.Applications.ViewModels.StudentApplicationDocumentsViewModel
@{
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
    ViewData["Title"] = Model.PageTitle;
}

<div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
    <div class="px-4 py-6 sm:px-0">
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-bold text-slate-900">@Model.PageTitle</h1>
            <a href="/student/applications/@Model.ApplicationId"
               class="text-sm font-medium text-slate-600 hover:text-slate-900">
                ← Quay lại chi tiết
            </a>
        </div>

        @if (Model.DocumentRequirements.Count == 0)
        {
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm text-center">
                <p class="text-slate-500">Không có yêu cầu hồ sơ cho chương trình này.</p>
            </div>
        }
        else
        {
            <div class="space-y-4">
                @foreach (var req in Model.DocumentRequirements)
                {
                    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm"
                         data-testid="doc-upload-form-@req.DocumentTypeId">
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex-1">
                                <div class="flex items-center gap-2 flex-wrap">
                                    <h2 class="text-lg font-semibold text-slate-900">@req.DocumentName</h2>
                                    @if (req.IsRequired)
                                    {
                                        <span class="rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-medium text-red-700">Bắt buộc</span>
                                    }
                                    else
                                    {
                                        <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-600">Tùy chọn</span>
                                    }
                                    @if (req.RequiresNotarization)
                                    {
                                        <span class="rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-medium text-amber-700">Cần công chứng</span>
                                    }
                                    @if (req.RequiresOriginalCopy)
                                    {
                                        <span class="rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-medium text-amber-700">Bản gốc</span>
                                    }
                                </div>
                                @if (!string.IsNullOrWhiteSpace(req.Description))
                                {
                                    <p class="mt-1 text-sm text-slate-500">@req.Description</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(req.Notes))
                                {
                                    <p class="mt-1 text-sm text-slate-400 italic">@req.Notes</p>
                                }
                            </div>
                            <div class="text-right shrink-0">
                                <div class="text-sm text-slate-500">Đã tải lên</div>
                                <div class="text-lg font-semibold text-slate-900">
                                    @req.UploadedCount / @req.MaxFiles
                                </div>
                            </div>
                        </div>

                        @* Uploaded files list *@
                        <div class="mt-4" data-testid="doc-uploaded-list-@req.DocumentTypeId">
                            @if (req.UploadedDocuments.Count > 0)
                            {
                                <ul class="divide-y divide-slate-100 rounded-xl border border-slate-100">
                                    @foreach (var doc in req.UploadedDocuments)
                                    {
                                        <li class="flex items-center justify-between px-4 py-3"
                                            data-testid="doc-uploaded-file-@doc.DocumentId">
                                            <div class="flex items-center gap-3 min-w-0">
                                                <svg class="h-5 w-5 shrink-0 text-red-500" fill="currentColor" viewBox="0 0 20 20">
                                                    <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd" />
                                                </svg>
                                                <div class="min-w-0">
                                                    <a href="/@doc.StoragePath"
                                                       target="_blank"
                                                       class="text-sm font-medium text-slate-900 hover:text-indigo-600 truncate block max-w-xs">
                                                        @doc.FileName
                                                    </a>
                                                    <div class="text-xs text-slate-400">
                                                        @(doc.FileSize / 1024) KB · @doc.UploadedAt
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="flex items-center gap-3 ml-4">
                                                <span class="rounded-full px-2.5 py-0.5 text-xs font-medium
                                                    @(doc.ValidationStatus == "VALID" ? "bg-green-100 text-green-700" :
                                                      doc.ValidationStatus == "REJECTED" ? "bg-red-100 text-red-700" :
                                                      "bg-amber-100 text-amber-700")">
                                                    @(doc.ValidationStatus == "PENDING" ? "Đang chờ" :
                                                      doc.ValidationStatus == "VALID" ? "Hợp lệ" :
                                                      doc.ValidationStatus == "REJECTED" ? "Từ chối" : doc.ValidationStatus)
                                                </span>
                                                <form action="/student/applications/@Model.ApplicationId/documents/@doc.DocumentId"
                                                      method="post"
                                                      onsubmit="if(!confirm('Xóa tệp này?')) return false; var token = this.querySelector('input[name=__RequestVerificationToken]').value; fetch(this.action, { method: 'DELETE', headers: { 'RequestVerificationToken': token } }).then(function(r){ if(r.ok) location.reload(); else alert('Xóa thất bại.'); }); return false;">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit"
                                                            class="text-sm text-red-600 hover:text-red-800 font-medium">
                                                        Xóa
                                                    </button>
                                                </form>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <div class="rounded-xl border border-dashed border-slate-200 bg-slate-50 px-4 py-6 text-center">
                                    <p class="text-sm text-slate-400">Chưa có tệp nào được tải lên</p>
                                </div>
                            }
                        </div>

                        @* Upload form — only show if under max *@
                        @if (req.UploadedCount < req.MaxFiles)
                        {
                            <div class="mt-4">
                                <form action="/student/applications/@Model.ApplicationId/upload"
                                      method="post"
                                      enctype="multipart/form-data"
                                      data-testid="doc-upload-form-@req.DocumentTypeId">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="documentTypeId" value="@req.DocumentTypeId" />
                                    <div class="flex items-center gap-3">
                                        <input type="file"
                                               name="file"
                                               id="doc-upload-input-@req.DocumentTypeId"
                                               data-testid="doc-upload-input-@req.DocumentTypeId"
                                               accept="application/pdf"
                                               class="block w-full text-sm text-slate-500
                                                      file:mr-4 file:py-2 file:px-4
                                                      file:rounded-lg file:border-0
                                                      file:text-sm file:font-semibold
                                                      file:bg-indigo-50 file:text-indigo-700
                                                      hover:file:bg-indigo-100
                                                      cursor-pointer" />
                                        <button type="submit"
                                                class="shrink-0 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white
                                                       hover:bg-indigo-700 disabled:opacity-50 disabled:cursor-not-allowed">
                                            Tải lên
                                        </button>
                                    </div>
                                    <p class="mt-1 text-xs text-slate-400">Chỉ chấp nhận tệp PDF, tối đa 5 MB.</p>
                                </form>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        @* Confirm submit section *@
        <div class="mt-8 flex items-center justify-end gap-4">
            <a href="/student/applications/@Model.ApplicationId"
               class="rounded-lg border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700
                      hover:bg-slate-50">
                Hủy
            </a>
            @if (Model.IsComplete)
            {
                <form action="/student/applications/@Model.ApplicationId/confirm"
                      method="post"
                      data-testid="confirm-submit-form">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            data-testid="confirm-submit-button"
                            class="rounded-lg bg-green-600 px-6 py-2.5 text-sm font-semibold text-white
                                   hover:bg-green-700">
                        Xác nhận nộp đơn
                    </button>
                </form>
            }
            else
            {
                <div data-testid="confirm-submit-disabled"
                     class="rounded-lg bg-slate-300 px-6 py-2.5 text-sm font-semibold text-slate-500
                            cursor-not-allowed"
                     title="Vui lòng tải lên đầy đủ hồ sơ bắt buộc trước khi nộp đơn.">
                    Xác nhận nộp đơn
                </div>
            }
        </div>
    </div>
</div>
