@model RoundProgramDetailsViewModel
@{
    ViewData["Title"] = "Round Program Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Round Program Details</h1>
        <p class="text-muted mb-0">@Model.RoundName</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Round</dt>
    <dd class="col-sm-9">@Model.RoundName</dd>
    <dt class="col-sm-3">Program</dt>
    <dd class="col-sm-9">@Model.ProgramName</dd>
    <dt class="col-sm-3">Major</dt>
    <dd class="col-sm-9">@Model.MajorName</dd>
    <dt class="col-sm-3">Quota</dt>
    <dd class="col-sm-9">@Model.Quota</dd>
    <dt class="col-sm-3">Published quota</dt>
    <dd class="col-sm-9">@Model.PublishedQuota</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
    <dt class="col-sm-3">Created at</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToString("u")</dd>
    <dt class="col-sm-3">Updated at</dt>
    <dd class="col-sm-9">@Model.UpdatedAt.ToString("u")</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Delete this round program?');">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">Delete</button>
</form>
