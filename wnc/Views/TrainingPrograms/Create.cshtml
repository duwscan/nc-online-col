@model TrainingProgramFormViewModel
@{
    ViewData["Title"] = "Create Training Program";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Create Training Program</h1>
    <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
</div>

<form asp-action="Create" method="post">
    <partial name="_Form" model="Model" />
    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-primary" type="submit">Save</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
