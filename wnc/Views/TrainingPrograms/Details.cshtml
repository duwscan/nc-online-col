@model TrainingProgramDetailsViewModel
@{
    ViewData["Title"] = "Training Program Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Training Program Details</h1>
        <p class="text-muted mb-0">@Model.ProgramCode</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Program code</dt>
    <dd class="col-sm-9">@Model.ProgramCode</dd>
    <dt class="col-sm-3">Program name</dt>
    <dd class="col-sm-9">@Model.ProgramName</dd>
    <dt class="col-sm-3">Education type</dt>
    <dd class="col-sm-9">@Model.EducationType</dd>
    <dt class="col-sm-3">Tuition fee</dt>
    <dd class="col-sm-9">@Model.TuitionFee</dd>
    <dt class="col-sm-3">Duration</dt>
    <dd class="col-sm-9">@Model.DurationText</dd>
    <dt class="col-sm-3">Quota</dt>
    <dd class="col-sm-9">@Model.Quota</dd>
    <dt class="col-sm-3">Managing unit</dt>
    <dd class="col-sm-9">@Model.ManagingUnit</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
    <dt class="col-sm-3">Display order</dt>
    <dd class="col-sm-9">@Model.DisplayOrder</dd>
    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.Description</dd>
    <dt class="col-sm-3">Created at</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToString("u")</dd>
    <dt class="col-sm-3">Updated at</dt>
    <dd class="col-sm-9">@Model.UpdatedAt.ToString("u")</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Delete this training program?');">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">Delete</button>
</form>
