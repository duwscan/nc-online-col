@model AdminLoginViewModel
@{
    ViewData["Title"] = "Admin Login";
}

<section class="admin-login-shell mx-auto w-full max-w-2xl">
    <div class="admin-login-card rounded-[28px] border border-slate-200 bg-white p-6 shadow-[0_28px_80px_rgba(15,23,42,0.08)] sm:p-8">
        <div class="space-y-6">
            <div class="space-y-4">
                <div class="admin-login-badge inline-flex w-fit items-center rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em]">
                    Internal Access
                </div>

                <div class="space-y-3">
                    <h1 class="text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">Admin sign in</h1>
                    <p class="max-w-xl text-sm leading-7 text-slate-600 sm:text-base">
                        Sign in with your staff email or registered phone number. This page only accepts internal roles.
                    </p>
                </div>

                <div class="flex flex-wrap gap-2">
                    <span class="admin-login-chip rounded-full px-3 py-2 text-xs font-medium text-slate-700">ADMIN</span>
                    <span class="admin-login-chip rounded-full px-3 py-2 text-xs font-medium text-slate-700">ADMISSION_OFFICER</span>
                    <span class="admin-login-chip rounded-full px-3 py-2 text-xs font-medium text-slate-700">REPORT_VIEWER</span>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div role="alert" aria-live="polite" class="admin-login-alert rounded-2xl px-4 py-3 text-sm leading-6 text-rose-700">
                    @Model.ErrorMessage
                </div>
            }

            <div asp-validation-summary="ModelOnly" role="alert" aria-live="polite" class="admin-login-alert rounded-2xl px-4 py-3 text-sm leading-6 text-rose-700"></div>

            <form method="post" action="/auth/admin/login" class="space-y-5">
                @Html.AntiForgeryToken()
                <input asp-for="ReturnUrl" type="hidden"/>

                <div class="space-y-2">
                    <label asp-for="LoginIdentifier" class="block text-sm font-medium text-slate-900"></label>
                    <p id="admin-login-identifier-help" class="text-sm leading-6 text-slate-500">
                        Use your work email address or your registered phone number.
                    </p>
                    <input asp-for="LoginIdentifier"
                           autocomplete="username"
                           aria-describedby="admin-login-identifier-help"
                           class="admin-login-input w-full rounded-2xl border border-slate-200 px-4 py-3 text-base text-slate-900 placeholder:text-slate-400"
                           placeholder="admin@wnc.local or 0900000001"/>
                    <span asp-validation-for="LoginIdentifier" class="text-sm text-rose-600"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Password" class="block text-sm font-medium text-slate-900"></label>
                    <p id="admin-password-help" class="text-sm leading-6 text-slate-500">
                        Enter your current internal password.
                    </p>
                    <input asp-for="Password"
                           autocomplete="current-password"
                           aria-describedby="admin-password-help"
                           class="admin-login-input w-full rounded-2xl border border-slate-200 px-4 py-3 text-base text-slate-900 placeholder:text-slate-400"
                           placeholder="Enter your password"/>
                    <span asp-validation-for="Password" class="text-sm text-rose-600"></span>
                </div>

                <button type="submit" class="admin-login-submit inline-flex min-h-12 w-full items-center justify-center rounded-2xl px-6 py-3 text-sm font-semibold text-white">
                    Sign in
                </button>
            </form>

            <div class="admin-login-meta grid gap-3 rounded-2xl border border-slate-200 px-4 py-4 text-sm leading-6 text-slate-600 sm:grid-cols-2">
                <div>
                    <p class="font-medium text-slate-900">Demo email</p>
                    <p><code>admin@wnc.local</code></p>
                </div>
                <div>
                    <p class="font-medium text-slate-900">Demo phone</p>
                    <p><code>0900000001</code></p>
                </div>
            </div>

            <div class="flex flex-col gap-3 border-t border-slate-200 pt-4 text-sm text-slate-600 sm:flex-row sm:items-center sm:justify-between">
                <p>Not staff? Use the <a href="/auth/student/login" class="font-medium text-slate-900 underline decoration-slate-300 underline-offset-4">student login</a>.</p>
                <a href="/" class="font-medium text-slate-900 underline decoration-slate-300 underline-offset-4">Back Home</a>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
