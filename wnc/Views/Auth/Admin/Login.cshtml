@model AdminLoginViewModel
@{
    ViewData["Title"] = "Đăng nhập Quản trị";
}

<section class="mx-auto max-w-md py-8">
    <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
        <div class="space-y-5">
            <div class="space-y-1">
                <span class="inline-block rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-slate-600">
                    Truy cập Nội bộ
                </span>
                <h1 class="text-xl font-semibold text-slate-900">Đăng nhập</h1>
                <p class="text-sm text-slate-500">Email công tác hoặc số điện thoại đã đăng ký.</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div role="alert" aria-live="polite" class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                    @Model.ErrorMessage
                </div>
            }

            <div asp-validation-summary="ModelOnly" role="alert" aria-live="polite" class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>

            <form method="post" action="/auth/admin/login" class="space-y-4">
                @Html.AntiForgeryToken()
                <input asp-for="ReturnUrl" type="hidden"/>

                <div class="space-y-1">
                    <label asp-for="LoginIdentifier" class="block text-sm font-medium text-slate-700"></label>
                    <input asp-for="LoginIdentifier"
                           autocomplete="username"
                           class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-base text-slate-900 placeholder:text-slate-400 focus:border-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-400"/>
                    <span asp-validation-for="LoginIdentifier" class="text-sm text-red-600"></span>
                </div>

                <div class="space-y-1">
                    <label asp-for="Password" class="block text-sm font-medium text-slate-700"></label>
                    <input asp-for="Password"
                           autocomplete="current-password"
                           type="password"
                           class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-base text-slate-900 placeholder:text-slate-400 focus:border-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-400"/>
                    <span asp-validation-for="Password" class="text-sm text-red-600"></span>
                </div>

                <button type="submit" class="w-full rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2">
                    Đăng nhập
                </button>
            </form>

            <p class="text-center text-sm text-slate-500">
                <a href="/" class="hover:text-slate-700">Về trang chủ</a>
            </p>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
