@model StudentLoginViewModel
@{
    ViewData["Title"] = "Đăng nhập Thí sinh";
}

<section class="mx-auto max-w-md pt-12">
    <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
        <div class="mb-6 text-center">
            <h1 class="text-2xl font-semibold text-slate-900">Đăng nhập Thí sinh</h1>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div role="alert" aria-live="polite" class="mb-5 rounded-xl border border-red-200 bg-red-50 px-5 py-4 text-sm text-red-700">
                @Model.ErrorMessage
            </div>
        }

        <div asp-validation-summary="ModelOnly" role="alert" aria-live="polite" class="mb-5 rounded-xl border border-red-200 bg-red-50 px-5 py-4 text-sm text-red-700"></div>

        <form method="post" action="/auth/student/login" class="space-y-5">
            @Html.AntiForgeryToken()
            <input asp-for="ReturnUrl" type="hidden"/>

            <div>
                <label asp-for="LoginIdentifier" class="block text-sm font-medium text-slate-700 mb-1"></label>
                <input asp-for="LoginIdentifier"
                       autocomplete="username"
                       class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base text-slate-900"
                       placeholder="Email hoặc số điện thoại"/>
                <span asp-validation-for="LoginIdentifier" class="text-sm text-rose-600"></span>
            </div>

            <div>
                <label asp-for="Password" class="block text-sm font-medium text-slate-700 mb-1"></label>
                <input asp-for="Password"
                       autocomplete="current-password"
                       class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base text-slate-900"
                       placeholder="Mật khẩu"/>
                <span asp-validation-for="Password" class="text-sm text-rose-600"></span>
            </div>

            <button type="submit" class="w-full min-h-11 rounded-xl bg-blue-600 px-6 py-3 text-sm font-semibold text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                Đăng nhập
            </button>
        </form>

        <div class="mt-6 border-t border-slate-200 pt-6 text-center text-sm text-slate-500">
            <p>Chưa có tài khoản? <a href="/auth/student/signup" class="font-medium text-blue-600 hover:text-blue-700">Đăng ký</a></p>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
