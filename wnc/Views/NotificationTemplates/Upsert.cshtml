@model NotificationTemplateFormModel
@{
    var actionName = ViewContext.RouteData.Values["action"]?.ToString() ?? "Create";
    var isEdit = string.Equals(actionName, "Edit", StringComparison.OrdinalIgnoreCase);
    ViewData["Title"] = isEdit ? "Edit Notification Template" : "Create Notification Template";
    var routeId = ViewContext.RouteData.Values["id"];
}

<h1 class="h3 mb-4">@ViewData["Title"]</h1>

<form asp-action="@actionName" asp-route-id="@routeId" method="post" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-md-4">
        <label asp-for="TemplateCode" class="form-label"></label>
        <input asp-for="TemplateCode" class="form-control" />
        <span asp-validation-for="TemplateCode" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="TemplateName" class="form-label"></label>
        <input asp-for="TemplateName" class="form-control" />
        <span asp-validation-for="TemplateName" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Channel" class="form-label"></label>
        <input asp-for="Channel" class="form-control" />
        <span asp-validation-for="Channel" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="SubjectTemplate" class="form-label"></label>
        <input asp-for="SubjectTemplate" class="form-control" />
        <span asp-validation-for="SubjectTemplate" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="BodyTemplate" class="form-label"></label>
        <textarea asp-for="BodyTemplate" class="form-control" rows="10"></textarea>
        <span asp-validation-for="BodyTemplate" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Status" class="form-label"></label>
        <input asp-for="Status" class="form-control" />
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="CreatedAt" class="form-label"></label>
        <input asp-for="CreatedAt" class="form-control" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" />
        <span asp-validation-for="CreatedAt" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="UpdatedAt" class="form-label"></label>
        <input asp-for="UpdatedAt" class="form-control" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" />
        <span asp-validation-for="UpdatedAt" class="text-danger"></span>
    </div>
    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
