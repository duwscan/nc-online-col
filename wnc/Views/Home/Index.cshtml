@{
    ViewData["Title"] = "Admissions Access";
}

<section class="space-y-8">
    <div class="grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
        <div class="clay-panel p-8 sm:p-10">
            <div class="max-w-2xl space-y-6">
                <div class="clay-chip inline-flex w-fit px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-clay-ink/78">
                    Access Overview
                </div>
                <div class="space-y-4">
                    <h1 class="text-3xl font-semibold tracking-tight text-clay-ink sm:text-5xl">
                        Clear entry points for applicants and internal staff.
                    </h1>
                    <p class="max-w-xl text-base leading-8 text-clay-muted">
                        This redesign prioritizes readable contrast, explicit role expectations, visible feedback, and navigation that does not pressure people into the wrong path.
                    </p>
                </div>
                <div class="flex flex-wrap gap-3">
                    <a href="/auth/student/login" class="clay-button inline-flex min-h-11 items-center justify-center px-6 py-3 text-sm font-semibold">
                        Go to Student Login
                    </a>
                    <a href="/auth/admin/login" class="clay-secondary-button inline-flex min-h-11 items-center justify-center px-6 py-3 text-sm font-semibold">
                        Go to Admin Login
                    </a>
                </div>
            </div>
        </div>

        <aside class="clay-panel-soft p-6 sm:p-7">
            <h2 class="text-lg font-semibold text-clay-ink">Design commitments</h2>
            <ul class="mt-4 space-y-3 text-sm leading-7 text-clay-muted">
                <li class="clay-chip px-4 py-3">Labels remain visible and are never replaced by placeholder-only fields.</li>
                <li class="clay-chip px-4 py-3">Error messages appear near the relevant form and use alert regions for assistive tech.</li>
                <li class="clay-chip px-4 py-3">The system explains what each login route is for before asking for credentials.</li>
            </ul>
        </aside>
    </div>

    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        <article class="clay-panel-soft p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-clay-muted">Student route</p>
            <h2 class="mt-3 text-xl font-semibold text-clay-ink">Supportive layout</h2>
            <p class="mt-3 text-sm leading-7 text-clay-muted">
                Applicants see a guided, low-friction flow with plain-language explanations and pre-sign-in guidance.
            </p>
        </article>
        <article class="clay-panel-soft p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-clay-muted">Admin route</p>
            <h2 class="mt-3 text-xl font-semibold text-clay-ink">Procedural layout</h2>
            <p class="mt-3 text-sm leading-7 text-clay-muted">
                Staff users see policy context, role eligibility, and a more operational form structure.
            </p>
        </article>
        <article class="clay-panel-soft p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-clay-muted">Audit logging</p>
            <h2 class="mt-3 text-xl font-semibold text-clay-ink">Visible accountability</h2>
            <p class="mt-3 text-sm leading-7 text-clay-muted">
                Login attempts are recorded with identifier, result, IP address, and user agent.
            </p>
        </article>
        <article class="clay-panel-soft p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-clay-muted">Session state</p>
            <h2 class="mt-3 text-xl font-semibold text-clay-ink">No hidden status</h2>
            <p class="mt-3 text-sm leading-7 text-clay-muted">
                The shared shell exposes the current authenticated identity and role chips whenever a session exists.
            </p>
        </article>
    </div>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <section class="clay-panel p-7 sm:p-8">
            <h2 class="text-2xl font-semibold text-clay-ink">Current session</h2>
            <p class="mt-3 text-sm leading-7 text-clay-muted">
                Signed in as <span class="font-medium text-clay-ink">@(User.Identity?.Name ?? "Unknown user")</span>.
            </p>
        </section>
    }
</section>
