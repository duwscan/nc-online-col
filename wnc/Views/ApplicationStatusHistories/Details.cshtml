@model ApplicationStatusHistory
@{
    ViewData["Title"] = "Application Status History Details";
}

<h1 class="h3 mb-4">Application Status History Details</h1>

<dl class="row">
    <dt class="col-sm-3">Application</dt>
    <dd class="col-sm-9">@Model.Application.ApplicationCode</dd>
    <dt class="col-sm-3">From status</dt>
    <dd class="col-sm-9">@(Model.FromStatus ?? "-")</dd>
    <dt class="col-sm-3">To status</dt>
    <dd class="col-sm-9">@Model.ToStatus</dd>
    <dt class="col-sm-3">Changed by</dt>
    <dd class="col-sm-9">@(Model.ChangedByUser?.Username ?? Model.ChangedByUser?.Email ?? "(system)")</dd>
    <dt class="col-sm-3">Changed at</dt>
    <dd class="col-sm-9">@Model.ChangedAt.ToString("yyyy-MM-dd HH:mm")</dd>
    <dt class="col-sm-3">Reason</dt>
    <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Reason) ? "-" : Model.Reason)</dd>
    <dt class="col-sm-3">Public note</dt>
    <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.PublicNote) ? "-" : Model.PublicNote)</dd>
    <dt class="col-sm-3">Internal note</dt>
    <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.InternalNote) ? "-" : Model.InternalNote)</dd>
</dl>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
        <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Delete this record?');">Delete</button>
    </form>
</div>
