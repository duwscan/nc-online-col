@model IndexPageViewModel<AdmissionMethodListItemViewModel>
@{
    ViewData["Title"] = Model.Title;
    var pager = new PagerViewModel
    {
        Page = Model.Result.Page,
        TotalPages = Model.Result.TotalPages,
        RouteValues = new Dictionary<string, string?>
        {
            ["Search"] = Model.Query.Search,
            ["SortBy"] = Model.Query.SortBy,
            ["Descending"] = Model.Query.Descending.ToString(),
            ["PageSize"] = Model.Query.NormalizedPageSize.ToString()
        }
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">@Model.Title</h1>
        <p class="text-muted mb-0">Admission method master data.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Create</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-6">
        <input class="form-control" type="text" name="Search" value="@Model.Query.Search" placeholder="@Model.SearchPlaceholder" />
    </div>
    <div class="col-md-2">
        <select class="form-select" name="PageSize">
            @foreach (var size in new[] { 10, 20, 50 })
            {
                <option value="@size" selected="@(Model.Query.NormalizedPageSize == size)">@size / page</option>
            }
        </select>
    </div>
    <input type="hidden" name="SortBy" value="@Model.Query.SortBy" />
    <input type="hidden" name="Descending" value="@Model.Query.Descending" />
    <input type="hidden" name="Page" value="1" />
    <div class="col-md-4 d-flex gap-2">
        <button class="btn btn-outline-primary" type="submit">Apply</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Reset</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
        <thead>
        <tr>
            <th><a asp-action="Index" asp-route-Search="@Model.Query.Search" asp-route-Page="1" asp-route-PageSize="@Model.Query.NormalizedPageSize" asp-route-SortBy="methodCode" asp-route-Descending="@(Model.Query.SortBy == "methodCode" ? (!Model.Query.Descending).ToString() : bool.FalseString)">Code</a></th>
            <th><a asp-action="Index" asp-route-Search="@Model.Query.Search" asp-route-Page="1" asp-route-PageSize="@Model.Query.NormalizedPageSize" asp-route-SortBy="methodName" asp-route-Descending="@(Model.Query.SortBy == "methodName" ? (!Model.Query.Descending).ToString() : bool.FalseString)">Method Name</a></th>
            <th>Status</th>
            <th>Updated</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @if (Model.Result.Items.Count == 0)
        {
            <tr>
                <td colspan="5" class="text-center text-muted">No records found.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.Result.Items)
            {
                <tr>
                    <td>@item.MethodCode</td>
                    <td>@item.MethodName</td>
                    <td>@item.Status</td>
                    <td>@item.UpdatedAt.ToString("u")</td>
                    <td class="text-nowrap">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Details</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this admission method?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<div class="d-flex justify-content-between align-items-center">
    <div class="text-muted">Total: @Model.Result.TotalCount</div>
    <partial name="_Pager" model="pager" />
</div>
