@{
    ViewData["Title"] = "Admission Round Management - Ajax Demo";
}

<div class="container mt-4">
    <h2 class="mb-4">
        <i class="bi bi-calendar-event"></i> Admission Round Management
        <small class="text-muted fs-6">- Ajax Demo (Module 3)</small>
    </h2>

    <div class="card">
        <div class="card-header bg-danger text-white">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h5 class="mb-0">Admission Rounds List</h5>
                    <small>Quản lý đợt tuyển sinh - Ajax Integration</small>
                </div>
                <div class="col-md-6 text-end">
                    <button class="btn btn-light" id="btnCreate">
                        <i class="bi bi-plus-circle"></i> Create (jQuery AJAX)
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label">Search</label>
                    <div class="input-group">
                        <input type="text" id="searchTerm" class="form-control"
                               placeholder="Code, Name or Notes..."
                               onkeypress="handleSearchKeypress(event)">
                        <button class="btn btn-outline-danger" type="button" onclick="searchRounds()">
                            <i class="bi bi-search"></i> Search (Fetch)
                        </button>
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Status</label>
                    <select id="filterStatus" class="form-select" onchange="searchRounds()">
                        <option value="">All</option>
                        <option value="DRAFT">Nháp</option>
                        <option value="PUBLISHED">Đã đăng tải</option>
                        <option value="CLOSED">Đã đóng</option>
                        <option value="ARCHIVED">Đã lưu trữ</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Year</label>
                    <select id="filterYear" class="form-select" onchange="searchRounds()">
                        <option value="">All Years</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Page Size</label>
                    <select id="pageSize" class="form-select" onchange="changePageSize()">
                        <option value="5">5</option>
                        <option value="10" selected>10</option>
                        <option value="20">20</option>
                        <option value="50">50</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-danger w-100" onclick="refreshWithXHR()">
                        <i class="bi bi-arrow-clockwise"></i> Refresh (XHR)
                    </button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover table-bordered" id="roundTable">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 12%">Code</th>
                            <th style="width: 20%">Name</th>
                            <th style="width: 8%">Year</th>
                            <th style="width: 18%">Date Range</th>
                            <th style="width: 10%">Status</th>
                            <th style="width: 8%">Programs</th>
                            <th style="width: 8%">Applications</th>
                            <th style="width: 16%">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="roundTableBody">
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <div class="spinner-border text-danger" role="status"></div>
                                <p class="mt-2">Loading data...</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="row align-items-center">
                <div class="col-md-6">
                    <p class="mb-0 text-muted">
                        Showing <span id="showingFrom">0</span> to <span id="showingTo">0</span> of <span id="totalCount">0</span> entries
                    </p>
                </div>
                <div class="col-md-6">
                    <nav aria-label="Round pagination">
                        <ul class="pagination justify-content-end mb-0" id="pagination">
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-code-slash"></i> Phương pháp Ajax trong bài thực hành</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-sm">
                    <thead class="table-primary">
                        <tr>
                            <th>Phương pháp</th>
                            <th>Chức năng</th>
                            <th>Ưu điểm</th>
                            <th>Nhược điểm</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="table-secondary">
                            <td><strong>XmlHttpRequest</strong></td>
                            <td><span class="badge bg-secondary">Refresh Data</span></td>
                            <td>Hỗ trợ tất cả trình duyệt, kiểm soát chi tiết</td>
                            <td>Code dài, callback phức tạp</td>
                        </tr>
                        <tr class="table-success">
                            <td><strong>Fetch API</strong></td>
                            <td><span class="badge bg-success">Search, Pagination</span></td>
                            <td>Syntax sạch, Promise-based, async/await</td>
                            <td>Không hỗ trợ IE cũ</td>
                        </tr>
                        <tr class="table-info">
                            <td><strong>jQuery AJAX</strong></td>
                            <td><span class="badge bg-primary">Create, Edit, Delete</span></td>
                            <td>Dễ dùng, global handlers, error handling</td>
                            <td>Phụ thuộc jQuery, kích thước lớn</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><i class="bi bi-diagram-3"></i> Luồng xử lý Ajax chi tiết</h5>
        </div>
        <div class="card-body">
            <div class="alert alert-primary mb-3">
                <h5 class="alert-heading"><i class="bi bi-info-circle"></i> Luồng: UI → JS → Controller → EF Core → DB → JSON → JS → DOM</h5>
            </div>

            <div class="row text-center g-3">
                <div class="col-md-1-5">
                    <div class="p-3 border rounded bg-primary text-white h-100">
                        <i class="bi bi-display fs-3"></i>
                        <h6 class="mt-2 mb-1">1. UI</h6>
                        <small>User click Search</small>
                    </div>
                    <i class="bi bi-arrow-down text-primary fs-4"></i>
                </div>
                <div class="col-md-1-5">
                    <div class="p-3 border rounded bg-success text-white h-100">
                        <i class="bi bi-filetype-js fs-3"></i>
                        <h6 class="mt-2 mb-1">2. JavaScript</h6>
                        <small>fetch() gọi API</small>
                    </div>
                    <i class="bi bi-arrow-down text-success fs-4"></i>
                </div>
                <div class="col-md-1-5">
                    <div class="p-3 border rounded bg-info text-white h-100">
                        <i class="bi bi-git fs-3"></i>
                        <h6 class="mt-2 mb-1">3. Controller</h6>
                        <small>Nhận request</small>
                    </div>
                    <i class="bi bi-arrow-down text-info fs-4"></i>
                </div>
                <div class="col-md-1-5">
                    <div class="p-3 border rounded bg-warning text-dark h-100">
                        <i class="bi bi-database fs-3"></i>
                        <h6 class="mt-2 mb-1">4. EF Core</h6>
                        <small>Skip().Take()</small>
                    </div>
                    <i class="bi bi-arrow-down text-warning fs-4"></i>
                </div>
                <div class="col-md-1-5">
                    <div class="p-3 border rounded bg-danger text-white h-100">
                        <i class="bi bi-server fs-3"></i>
                        <h6 class="mt-2 mb-1">5. Database</h6>
                        <small>SQL Query</small>
                    </div>
                    <i class="bi bi-arrow-down text-danger fs-4"></i>
                </div>
            </div>

            <div class="row text-center g-3 mt-1">
                <div class="col-md-1-5"></div>
                <div class="col-md-1-5"></div>
                <div class="col-md-1-5"></div>
                <div class="col-md-1-5"></div>
                <div class="col-md-1-5"></div>
            </div>

            <div class="row text-center g-3 mt-1">
                <div class="col-md-1-5">
                    <i class="bi bi-arrow-up text-secondary fs-4"></i>
                    <div class="p-3 border rounded bg-light h-100">
                        <i class="bi bi-display fs-3 text-primary"></i>
                        <h6 class="mt-2 mb-1">8. DOM</h6>
                        <small>Cập nhật bảng</small>
                    </div>
                    <i class="bi bi-arrow-left text-secondary fs-4"></i>
                </div>
                <div class="col-md-1-5">
                    <i class="bi bi-arrow-left text-secondary fs-4"></i>
                    <div class="p-3 border rounded bg-light h-100">
                        <i class="bi bi-braces fs-3 text-secondary"></i>
                        <h6 class="mt-2 mb-1">7. JS Render</h6>
                        <small>Xử lý JSON</small>
                    </div>
                    <i class="bi bi-arrow-left text-secondary fs-4"></i>
                </div>
                <div class="col-md-1-5">
                    <i class="bi bi-arrow-left text-secondary fs-4"></i>
                    <div class="p-3 border rounded bg-light h-100">
                        <i class="bi bi-braces fs-3 text-dark"></i>
                        <h6 class="mt-2 mb-1">6. JSON</h6>
                        <small>Serialize</small>
                    </div>
                </div>
                <div class="col-md-1-5"></div>
                <div class="col-md-1-5"></div>
            </div>

            <div class="alert alert-secondary mt-3 mb-0">
                <h6><i class="bi bi-code"></i> Code EF Core Pagination:</h6>
                <code class="text-danger">.Skip((page - 1) * pageSize).Take(pageSize)</code>
                <hr class="my-2">
                <h6><i class="bi bi-check-circle"></i> Controller trả JSON:</h6>
                <code class="text-success">return Json(result);</code>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="bi bi-lightning"></i> So sánh Request truyền thống vs Ajax</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="alert alert-secondary mb-0">
                        <h6 class="text-danger"><i class="bi bi-x-circle"></i> Request Truyền thống</h6>
                        <ol class="mb-0 mt-2">
                            <li>User click/submit</li>
                            <li>Browser gửi HTTP Request</li>
                            <li>Server xử lý + Render HTML</li>
                            <li class="text-danger"><strong>Server trả về TOÀN BỘ trang HTML</strong></li>
                            <li>Browser reload toàn bộ trang</li>
                        </ol>
                        <hr>
                        <strong>Nhược điểm:</strong> Chậm, tốn băng thông, mất trạng thái
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="alert alert-success mb-0">
                        <h6 class="text-success"><i class="bi bi-check-circle"></i> AJAX</h6>
                        <ol class="mb-0 mt-2">
                            <li>User tương tác (click/search)</li>
                            <li><strong>JS gửi AJAX Request (XHR/Fetch)</strong></li>
                            <li>Server xử lý + Trả JSON</li>
                            <li class="text-success"><strong>JS nhận JSON → Render DOM</strong></li>
                            <li>Chỉ cập nhật phần tử cần thiết</li>
                        </ol>
                        <hr>
                        <strong>Ưu điểm:</strong> Nhanh, mượt, trải nghiệm tốt
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="roundModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="modalTitle">Create Admission Round</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalBody">
                <div class="text-center py-4">
                    <div class="spinner-border text-danger" role="status"></div>
                </div>
            </div>
            <div class="modal-footer" id="modalFooter">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-danger" id="btnSave">
                    <i class="bi bi-save"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title">Delete Round</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle"></i>
                    Are you sure you want to delete this admission round?
                </div>
                <input type="hidden" id="deleteRoundId">
                <p class="fw-bold" id="deleteRoundName"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-dark" id="btnConfirmDelete">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="detailModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title">Round Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="detailModalBody">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admission-round-ajax.js"></script>
}
