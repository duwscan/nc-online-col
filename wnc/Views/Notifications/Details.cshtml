@model Notification
@{
    ViewData["Title"] = "Notification Details";
}

<h1 class="h3 mb-4">Notification Details</h1>

<dl class="row">
    <dt class="col-sm-3">User</dt>
    <dd class="col-sm-9">@(Model.User.Username ?? Model.User.Email)</dd>
    <dt class="col-sm-3">Application</dt>
    <dd class="col-sm-9">@(Model.Application?.ApplicationCode ?? "-")</dd>
    <dt class="col-sm-3">Template</dt>
    <dd class="col-sm-9">@(Model.Template?.TemplateCode ?? "-")</dd>
    <dt class="col-sm-3">Channel</dt>
    <dd class="col-sm-9">@Model.Channel</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
    <dt class="col-sm-3">Created at</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
    <dt class="col-sm-3">Sent at</dt>
    <dd class="col-sm-9">@(Model.SentAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</dd>
    <dt class="col-sm-3">Read at</dt>
    <dd class="col-sm-9">@(Model.ReadAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</dd>
    <dt class="col-sm-3">Title</dt>
    <dd class="col-sm-9">@Model.Title</dd>
    <dt class="col-sm-3">Content</dt>
    <dd class="col-sm-9" style="white-space: pre-wrap">@Model.Content</dd>
</dl>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
        <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Delete this record?');">Delete</button>
    </form>
</div>
