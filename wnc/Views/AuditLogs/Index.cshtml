@model ListPageViewModel<AuditLogIndexQuery, AuditLogListItem>
@{
    ViewData["Title"] = "Audit Logs";
}

@await Html.PartialAsync("_StatusMessage")

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Audit Logs</h1>
        <p class="text-muted mb-0">Operational audit trail with reusable search, filter, and paging.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</div>

<form method="get" class="row g-3 mb-4">
    <input type="hidden" name="Page" value="1" />
    <div class="col-md-4">
        <label class="form-label" for="search">Search</label>
        <input id="search" name="Search" value="@Model.Query.Search" class="form-control" placeholder="Entity, action, actor, IP..." />
    </div>
    <div class="col-md-2">
        <label class="form-label" for="entityName">Entity</label>
        <input id="entityName" name="EntityName" value="@Model.Query.EntityName" class="form-control" />
    </div>
    <div class="col-md-2">
        <label class="form-label" for="actionFilter">Action</label>
        <input id="actionFilter" name="AuditAction" value="@Model.Query.AuditAction" class="form-control" />
    </div>
    <div class="col-md-2">
        <label class="form-label" for="sortBy">Sort by</label>
        <select id="sortBy" name="SortBy" class="form-select">
            <option value="createdat" selected="@((Model.Query.SortBy ?? "createdat") == "createdat")">Created at</option>
            <option value="actor" selected="@(Model.Query.SortBy == "actor")">Actor</option>
            <option value="entityname" selected="@(Model.Query.SortBy == "entityname")">Entity</option>
            <option value="action" selected="@(Model.Query.SortBy == "action")">Action</option>
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label" for="pageSize">Page size</label>
        <select id="pageSize" name="PageSize" class="form-select">
            <option value="10" selected="@(Model.Query.PageSize == 10)">10</option>
            <option value="20" selected="@(Model.Query.PageSize == 20)">20</option>
            <option value="50" selected="@(Model.Query.PageSize == 50)">50</option>
        </select>
    </div>
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div class="form-check">
            <input id="descending" name="Descending" value="true" checked="@Model.Query.Descending" class="form-check-input" type="checkbox" />
            <label for="descending" class="form-check-label">Descending</label>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-outline-primary">Apply</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
        </div>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
        <tr>
            <th>Actor</th>
            <th>Entity</th>
            <th>Entity ID</th>
            <th>Action</th>
            <th>IP</th>
            <th>Created at</th>
            <th class="text-end">Actions</th>
        </tr>
        </thead>
        <tbody>
        @if (Model.Results.Items.Count == 0)
        {
            <tr>
                <td colspan="7" class="text-center text-muted py-4">No records found.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.Results.Items)
            {
                <tr>
                    <td>@item.ActorDisplay</td>
                    <td>@item.EntityName</td>
                    <td>@(item.EntityId ?? "-")</td>
                    <td>@item.Action</td>
                    <td>@(item.IpAddress ?? "-")</td>
                    <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this record?');">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<div class="d-flex justify-content-between align-items-center">
    <span class="text-muted">Page @Model.Results.Page of @Model.Results.TotalPages, total @Model.Results.TotalCount records</span>
    <div class="btn-group">
        <a asp-action="Index"
           asp-route-page="@(Model.Results.Page - 1)"
           asp-route-pageSize="@Model.Results.PageSize"
           asp-route-search="@Model.Query.Search"
           asp-route-entityName="@Model.Query.EntityName"
           asp-route-auditAction="@Model.Query.AuditAction"
           asp-route-sortBy="@Model.Query.SortBy"
           asp-route-descending="@Model.Query.Descending"
           class="btn btn-outline-secondary @(Model.Results.HasPreviousPage ? string.Empty : "disabled")">Previous</a>
        <a asp-action="Index"
           asp-route-page="@(Model.Results.Page + 1)"
           asp-route-pageSize="@Model.Results.PageSize"
           asp-route-search="@Model.Query.Search"
           asp-route-entityName="@Model.Query.EntityName"
           asp-route-auditAction="@Model.Query.AuditAction"
           asp-route-sortBy="@Model.Query.SortBy"
           asp-route-descending="@Model.Query.Descending"
           class="btn btn-outline-secondary @(Model.Results.HasNextPage ? string.Empty : "disabled")">Next</a>
    </div>
</div>
