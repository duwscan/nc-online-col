@model AuditLog
@{
    ViewData["Title"] = "Audit Log Details";
}

<h1 class="h3 mb-4">Audit Log Details</h1>

<dl class="row">
    <dt class="col-sm-3">Actor</dt>
    <dd class="col-sm-9">@(Model.ActorUser?.Username ?? Model.ActorUser?.Email ?? "(system)")</dd>
    <dt class="col-sm-3">Entity name</dt>
    <dd class="col-sm-9">@Model.EntityName</dd>
    <dt class="col-sm-3">Entity ID</dt>
    <dd class="col-sm-9">@(Model.EntityId ?? "-")</dd>
    <dt class="col-sm-3">Action</dt>
    <dd class="col-sm-9">@Model.Action</dd>
    <dt class="col-sm-3">IP address</dt>
    <dd class="col-sm-9">@(Model.IpAddress ?? "-")</dd>
    <dt class="col-sm-3">Created at</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
    <dt class="col-sm-3">Old data</dt>
    <dd class="col-sm-9" style="white-space: pre-wrap">@(string.IsNullOrWhiteSpace(Model.OldData) ? "-" : Model.OldData)</dd>
    <dt class="col-sm-3">New data</dt>
    <dd class="col-sm-9" style="white-space: pre-wrap">@(string.IsNullOrWhiteSpace(Model.NewData) ? "-" : Model.NewData)</dd>
</dl>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
        <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Delete this record?');">Delete</button>
    </form>
</div>
