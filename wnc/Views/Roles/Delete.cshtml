@model wnc.Features.IdentityAccess.Roles.RoleDetailsViewModel

@{
    ViewData["Title"] = "Delete Role";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Delete role</h1>
        <p class="text-muted mb-0">System roles or roles with assignments are blocked from deletion.</p>
    </div>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Back to details</a>
</div>

<div class="card border-danger shadow-sm">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <dl class="row mb-0">
            <dt class="col-sm-3">Code</dt>
            <dd class="col-sm-9">@Model.Code</dd>
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>
            <dt class="col-sm-3">System role</dt>
            <dd class="col-sm-9">@(Model.IsSystemRole ? "Yes" : "No")</dd>
            <dt class="col-sm-3">Assignments</dt>
            <dd class="col-sm-9">@Model.Assignments.Count</dd>
        </dl>
    </div>
    <div class="card-footer d-flex justify-content-end">
        <form asp-action="Delete" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger">Delete role</button>
        </form>
    </div>
</div>
