@model wnc.Features.IdentityAccess.Roles.RolesIndexViewModel

@{
    ViewData["Title"] = "Roles";

    string NextDirection(string sortBy) =>
        string.Equals(Model.Query.SortBy, sortBy, StringComparison.OrdinalIgnoreCase) && !Model.Query.IsDescending()
            ? "desc"
            : "asc";

    string SortIndicator(string sortBy)
    {
        if (!string.Equals(Model.Query.SortBy, sortBy, StringComparison.OrdinalIgnoreCase))
        {
            return string.Empty;
        }

        return Model.Query.IsDescending() ? "▼" : "▲";
    }

    Dictionary<string, string> SortRoute(string sortBy) => Model.Query.BuildRouteValues(sortBy, NextDirection(sortBy), 1);
    var codeSortRoute = SortRoute("code");
    var nameSortRoute = SortRoute("name");
    var assignmentsSortRoute = SortRoute("assignments");
    var updatedSortRoute = SortRoute("updatedAt");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Roles</h1>
        <p class="text-muted mb-0">Manage access catalogs and inspect assignment volume.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Create role</a>
</div>

<form method="get" class="card shadow-sm mb-4">
    <div class="card-body row g-3 align-items-end">
        <div class="col-lg-5">
            <label asp-for="Query.SearchTerm" class="form-label">Search</label>
            <input asp-for="Query.SearchTerm" class="form-control" placeholder="Code, name or description" />
        </div>
        <div class="col-lg-3">
            <label asp-for="Query.IsSystemRole" class="form-label">Role type</label>
            <select asp-for="Query.IsSystemRole" asp-items="Model.RoleTypeOptions" class="form-select"></select>
        </div>
        <div class="col-lg-2">
            <label asp-for="Query.PageSize" class="form-label">Page size</label>
            <select asp-for="Query.PageSize" class="form-select">
                <option value="5">5</option>
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
            </select>
        </div>
        <div class="col-lg-2 d-grid">
            <button type="submit" class="btn btn-outline-primary">Apply</button>
        </div>
    </div>
</form>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
            <tr>
                <th><a asp-action="Index" asp-all-route-data="codeSortRoute" class="text-decoration-none">Code @SortIndicator("code")</a></th>
                <th><a asp-action="Index" asp-all-route-data="nameSortRoute" class="text-decoration-none">Name @SortIndicator("name")</a></th>
                <th>Type</th>
                <th><a asp-action="Index" asp-all-route-data="assignmentsSortRoute" class="text-decoration-none">Assignments @SortIndicator("assignments")</a></th>
                <th><a asp-action="Index" asp-all-route-data="updatedSortRoute" class="text-decoration-none">Updated @SortIndicator("updatedAt")</a></th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            @if (Model.Result.Items.Count == 0)
            {
                <tr>
                    <td colspan="6" class="text-center py-4 text-muted">No roles matched the current query.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model.Result.Items)
                {
                    <tr>
                        <td><code>@item.Code</code></td>
                        <td>
                            <div class="fw-semibold">@item.Name</div>
                            <div class="text-muted small">@item.Description</div>
                        </td>
                        <td>@(item.IsSystemRole ? "System" : "Custom")</td>
                        <td>@item.ActiveAssignmentCount</td>
                        <td>@item.UpdatedAt.ToString("g")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center">
        <span class="text-muted">Showing @Model.Result.StartItem-@Model.Result.EndItem of @Model.Result.TotalCount</span>
        <div class="btn-group">
            <a asp-action="Index"
               asp-all-route-data="Model.Query.BuildRouteValues(page: Model.Result.Page - 1)"
               class="btn btn-outline-secondary @(Model.Result.HasPreviousPage ? string.Empty : "disabled")">Previous</a>
            <span class="btn btn-outline-secondary disabled">Page @Model.Result.Page / @Model.Result.TotalPages</span>
            <a asp-action="Index"
               asp-all-route-data="Model.Query.BuildRouteValues(page: Model.Result.Page + 1)"
               class="btn btn-outline-secondary @(Model.Result.HasNextPage ? string.Empty : "disabled")">Next</a>
        </div>
    </div>
</div>
