@{
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var isAdminPortalUser = User.IsInRole("ADMIN")
                            || User.IsInRole("ADMISSION_OFFICER")
                            || User.IsInRole("REPORT_VIEWER");
    var logoutPath = isAdminPortalUser ? "/auth/admin/logout" : "/auth/student/logout";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - wnc</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body class="min-h-screen overflow-x-hidden text-clay-ink">
<main class="mx-auto w-full max-w-5xl px-5 py-8 sm:px-8 lg:px-10">
    <div class="mb-8 flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between">

        @if (isAuthenticated)
        {
            <div class="clay-panel-soft flex flex-col gap-3 px-5 py-4 text-sm sm:min-w-80">
                <div class="font-medium text-clay-ink">@(User.Identity?.Name ?? "Authenticated user")</div>
                <div class="flex flex-wrap gap-2">
                    @foreach (var claim in User.Claims.Where(x => x.Type == System.Security.Claims.ClaimTypes.Role).Select(x => x.Value).Distinct())
                    {
                        <span class="clay-chip px-3 py-1 text-xs font-medium text-clay-ink/80">@claim</span>
                    }
                </div>
                <a href="@logoutPath" class="clay-secondary-button inline-flex w-fit items-center justify-center px-4 py-2 text-sm font-medium">Logout</a>
            </div>
        }
    </div>

    @RenderBody()
</main>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
