@{
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var isAdminPortalUser = User.IsInRole("ADMIN")
                            || User.IsInRole("ADMISSION_OFFICER")
                            || User.IsInRole("REPORT_VIEWER");
    var logoutPath = isAdminPortalUser ? "/auth/admin/logout" : "/auth/student/logout";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - wnc</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body class="min-h-screen overflow-x-hidden bg-slate-50">
<!-- Header -->
<header class="bg-blue-600 text-white">
    <nav class="mx-auto flex max-w-5xl items-center justify-between px-5 py-4 sm:px-8">
        <a href="/" class="text-lg font-semibold">Trường Đại học Công nghệ</a>
        <div class="flex items-center gap-6">
            <a href="/" class="text-sm font-medium hover:text-blue-200">Trang chủ</a>
            @if (isAuthenticated)
            {
                <span class="text-sm">@(User.Identity?.Name ?? "User")</span>
                <a href="@logoutPath" class="rounded bg-white/20 px-4 py-1.5 text-sm font-medium hover:bg-white/30">Đăng xuất</a>
            }
            else
            {
                <a href="/auth/student/login" class="text-sm font-medium hover:text-blue-200">Đăng nhập</a>
                <a href="/auth/student/register" class="rounded bg-white px-4 py-1.5 text-sm font-medium text-blue-600 hover:bg-blue-50">Đăng ký</a>
            }
        </div>
    </nav>
</header>

<main class="mx-auto w-full max-w-5xl px-5 py-8 sm:px-8 lg:px-10">
    @RenderBody()
</main>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
