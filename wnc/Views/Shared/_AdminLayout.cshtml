@{
    var pageTitle = ViewData["Title"]?.ToString() ?? "Admin Dashboard";
    var displayName = User.Identity?.Name ?? "Admin User";
    var currentPath = Context.Request.Path.Value ?? string.Empty;
    var isDashboardPage = currentPath.StartsWith("/admin/dashboard", StringComparison.OrdinalIgnoreCase);
    var isStaffManagementPage = currentPath.StartsWith("/admin/staff", StringComparison.OrdinalIgnoreCase);
    var isProgramManagementPage = currentPath.StartsWith("/admin/programs", StringComparison.OrdinalIgnoreCase);
    var isMajorManagementPage = currentPath.StartsWith("/admin/majors", StringComparison.OrdinalIgnoreCase);
    var isRoundsPage = currentPath.StartsWith("/admin/rounds", StringComparison.OrdinalIgnoreCase);
    var isMethodsPage = currentPath.StartsWith("/admin/methods", StringComparison.OrdinalIgnoreCase) || currentPath.StartsWith("/admin/rounds", StringComparison.OrdinalIgnoreCase) && currentPath.Contains("/methods");
    var currentRoundId = ViewData["CurrentRoundId"] as Guid?;
    var methodsLink = currentRoundId.HasValue ? $"/admin/rounds/{currentRoundId}/methods" : "/admin/methods";
    var isDocumentTypesPage = currentPath.StartsWith("/admin/document-types", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - WNC Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="min-h-screen bg-slate-50 font-['Inter','Outfit',sans-serif] text-slate-800">
    <div class="relative min-h-screen lg:flex">
        <div id="admin-sidebar-overlay" class="fixed inset-0 z-30 hidden bg-slate-950/40 lg:hidden"></div>

        <aside id="admin-sidebar" class="fixed inset-y-0 left-0 z-40 flex w-72 -translate-x-full flex-col border-r border-slate-200 bg-white transition-transform duration-200 ease-out lg:sticky lg:top-0 lg:h-screen lg:translate-x-0">
            <div class="flex h-20 items-center justify-between border-b border-slate-200 px-6">
                <a href="/admin/dashboard" class="flex items-center gap-3 text-slate-900">
                    <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-blue-600 text-base font-semibold text-white">W</span>
                    <span>
                        <span class="block text-xs font-semibold uppercase tracking-[0.24em] text-blue-600">WNC Portal</span>
                        <span class="block text-lg font-semibold text-slate-900">Bảng điều khiển</span>
                    </span>
                </a>
                <button type="button" id="admin-sidebar-close" class="inline-flex h-10 w-10 items-center justify-center rounded-xl text-slate-500 hover:bg-slate-100 hover:text-slate-700 lg:hidden" aria-label="Close navigation">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 18 18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <nav class="flex-1 space-y-8 overflow-y-auto px-4 py-6">
                <div class="space-y-1.5">
                    <a href="/admin/dashboard" class="@(isDashboardPage ? "flex items-center gap-3 rounded-xl bg-blue-50 px-4 py-3 text-sm font-medium text-blue-600" : "flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-medium text-slate-600 hover:bg-slate-100 hover:text-blue-600")">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3.75 9.75 12 3l8.25 6.75v9a2.25 2.25 0 0 1-2.25 2.25h-12A2.25 2.25 0 0 1 3.75 18.75v-9Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 21v-6.75A2.25 2.25 0 0 1 11.25 12h1.5A2.25 2.25 0 0 1 15 14.25V21" />
                        </svg>
                        Trang chủ
                    </a>

                    <div class="rounded-2xl px-2 py-1">
                        <div class="flex items-center gap-3 px-2 py-2 text-sm font-medium text-slate-600">
                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M16 21v-2.25A3.75 3.75 0 0 0 12.25 15h-4.5A3.75 3.75 0 0 0 4 18.75V21" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M14.5 7.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm5.5 13.5v-2.25A3.75 3.75 0 0 0 17 15.114M14.75 4.965a3 3 0 0 1 0 5.57" />
                            </svg>
                            Quản lý người dùng
                        </div>
                        <div class="ml-8 space-y-1 border-l border-slate-200 pl-4">
                            <a href="/admin/staff" class="@(isStaffManagementPage ? "block rounded-lg bg-blue-50 px-3 py-2 text-sm font-medium text-blue-600" : "block rounded-lg px-3 py-2 text-sm text-slate-500 hover:bg-slate-100 hover:text-blue-600")">Quản lý nhân viên</a>
                        </div>
                    </div>

                    <div class="rounded-2xl px-2 py-1">
                        <div class="flex items-center gap-3 px-2 py-2 text-sm font-medium text-slate-600">
                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 5.25H7.5A2.25 2.25 0 0 0 5.25 7.5v10.5a2.25 2.25 0 0 0 2.25 2.25h9A2.25 2.25 0 0 0 18.75 18V7.5a2.25 2.25 0 0 0-2.25-2.25H15M9 5.25A2.25 2.25 0 0 1 11.25 3h1.5A2.25 2.25 0 0 1 15 5.25M9 5.25A2.25 2.25 0 0 0 11.25 7.5h1.5A2.25 2.25 0 0 0 15 5.25" />
                            </svg>
                            Tuyển sinh
                        </div>
                        <div class="ml-8 space-y-1 border-l border-slate-200 pl-4">
                            <a href="/admin/rounds" class="@(!isRoundsPage && !isMethodsPage && !isDocumentTypesPage ? "block rounded-lg bg-blue-50 px-3 py-2 text-sm font-medium text-blue-600" : "block rounded-lg px-3 py-2 text-sm text-slate-500 hover:bg-slate-100 hover:text-blue-600")">Đợt xét tuyển</a>
                            <a href="/admin/document-types" class="@(isDocumentTypesPage ? "block rounded-lg bg-blue-50 px-3 py-2 text-sm font-medium text-blue-600" : "block rounded-lg px-3 py-2 text-sm text-slate-500 hover:bg-slate-100 hover:text-blue-600")">Loại giấy tờ</a>
                            <a href="@methodsLink" class="@(isMethodsPage ? "block rounded-lg bg-blue-50 px-3 py-2 text-sm font-medium text-blue-600" : "block rounded-lg px-3 py-2 text-sm text-slate-500 hover:bg-slate-100 hover:text-blue-600")">Phương thức xét tuyển</a>
                            <a href="/admin/programs" class="@(isProgramManagementPage ? "block rounded-lg bg-blue-50 px-3 py-2 text-sm font-medium text-blue-600" : "block rounded-lg px-3 py-2 text-sm text-slate-500 hover:bg-slate-100 hover:text-blue-600")">Chương trình đào tạo</a>
                            <a href="/admin/majors" class="@(isMajorManagementPage ? "block rounded-lg bg-blue-50 px-3 py-2 text-sm font-medium text-blue-600" : "block rounded-lg px-3 py-2 text-sm text-slate-500 hover:bg-slate-100 hover:text-blue-600")">Ngành học</a>
                            <a href="#" class="block rounded-lg px-3 py-2 text-sm text-slate-500 hover:bg-slate-100 hover:text-blue-600">Thí sinh</a>
                            <a href="#" class="block rounded-lg px-3 py-2 text-sm text-slate-500 hover:bg-slate-100 hover:text-blue-600">Hồ sơ ứng tuyển</a>
                        </div>
                    </div>

                    <a href="#" class="flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-medium text-slate-600 hover:bg-slate-100 hover:text-blue-600">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M7.5 17.25v-10.5m4.5 10.5V10.5m4.5 6.75V13.5m-9 6.75h10.5A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25h1.5Z" />
                        </svg>
                        Báo cáo
                    </a>

                    <a href="#" class="flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-medium text-slate-600 hover:bg-slate-100 hover:text-blue-600">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M10.5 6h3m-7.156 2.629 1.06-1.837a1.125 1.125 0 0 1 1.949 0l1.06 1.837a1.125 1.125 0 0 0 .974.563h2.12a1.125 1.125 0 0 1 .974 1.687l-1.06 1.837a1.125 1.125 0 0 0 0 1.124l1.06 1.837a1.125 1.125 0 0 1-.974 1.687h-2.12a1.125 1.125 0 0 0-.974.563l-1.06 1.837a1.125 1.125 0 0 1-1.949 0l-1.06-1.837a1.125 1.125 0 0 0-.974-.563h-2.12a1.125 1.125 0 0 1-.974-1.687l1.06-1.837a1.125 1.125 0 0 0 0-1.124l-1.06-1.837a1.125 1.125 0 0 1 .974-1.687h2.12a1.125 1.125 0 0 0 .974-.563Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 15.75a3.75 3.75 0 1 0 0-7.5 3.75 3.75 0 0 0 0 7.5Z" />
                        </svg>
                        Cài đặt
                    </a>
                </div>
            </nav>

            <div class="border-t border-slate-200 p-4">
                <a href="/auth/admin/logout" class="flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-medium text-slate-600 hover:bg-slate-100 hover:text-rose-600">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6A2.25 2.25 0 0 0 5.25 5.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 12h9m0 0-3-3m3 3-3 3" />
                    </svg>
                    Đăng xuất
                </a>
            </div>
        </aside>

        <div class="flex min-h-screen flex-1 flex-col">
            <main class="flex-1">
                <div class="mx-auto w-full max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
                    <section class="mb-8 flex flex-col gap-3 border-b border-slate-200 pb-6 sm:flex-row sm:items-end sm:justify-between">
                        <div>
                            <p class="text-sm font-medium text-blue-600">Tổng quan thao tác</p>
                            <h2 class="mt-1 text-3xl font-semibold tracking-tight text-slate-900">@pageTitle</h2>
                            <p class="mt-2 max-w-2xl text-sm text-slate-500">Không gian làm việc tập trung cho các hoạt động tuyển sinh, báo cáo và quy trình quản trị.</p>
                        </div>
                    </section>

                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function () {
            const sidebar = document.getElementById('admin-sidebar');
            const overlay = document.getElementById('admin-sidebar-overlay');
            const openButton = document.getElementById('admin-sidebar-open');
            const closeButton = document.getElementById('admin-sidebar-close');

            if (!sidebar || !overlay || !openButton || !closeButton) {
                return;
            }

            const openSidebar = function () {
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
                document.body.classList.add('overflow-hidden');
            };

            const closeSidebar = function () {
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('hidden');
                document.body.classList.remove('overflow-hidden');
            };

            openButton.addEventListener('click', openSidebar);
            closeButton.addEventListener('click', closeSidebar);
            overlay.addEventListener('click', closeSidebar);
            window.addEventListener('resize', function () {
                if (window.innerWidth >= 1024) {
                    overlay.classList.add('hidden');
                    document.body.classList.remove('overflow-hidden');
                    sidebar.classList.remove('-translate-x-full');
                    return;
                }

                sidebar.classList.add('-translate-x-full');
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
