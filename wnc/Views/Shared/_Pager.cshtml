@model wnc.ViewModels.Shared.PagerViewModel

@if (Model.TotalPages > 1)
{
    <nav aria-label="Pagination">
        <ul class="pagination justify-content-end">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : null)">
                <a class="page-link"
                   asp-action="@Model.Action"
                   asp-all-route-data="@(new Dictionary<string, string?>(Model.RouteValues)
                   {
                       ["Page"] = (Model.Page - 1).ToString()
                   })">
                    Trước
                </a>
            </li>

            @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
            {
                <li class="page-item @(pageNumber == Model.Page ? "active" : null)">
                    <a class="page-link"
                       asp-action="@Model.Action"
                       asp-all-route-data="@(new Dictionary<string, string?>(Model.RouteValues)
                       {
                           ["Page"] = pageNumber.ToString()
                       })">
                        @pageNumber
                    </a>
                </li>
            }

            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : null)">
                <a class="page-link"
                   asp-action="@Model.Action"
                   asp-all-route-data="@(new Dictionary<string, string?>(Model.RouteValues)
                   {
                       ["Page"] = (Model.Page + 1).ToString()
                   })">
                    Sau
                </a>
            </li>
        </ul>
    </nav>
}
