@model ErrorViewModel
@{
    ViewData["Title"] = "Request Error";
}

<section class="mx-auto max-w-4xl space-y-6">
    <div class="clay-panel p-8 sm:p-10">
        <div class="space-y-5">
            <div class="clay-chip inline-flex w-fit px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-clay-ink/78">
                Error State
            </div>
            <div class="space-y-3">
                <h1 class="text-3xl font-semibold tracking-tight text-clay-ink sm:text-4xl">We could not complete that request.</h1>
                <p class="max-w-2xl text-base leading-8 text-clay-muted">
                    The message here is intentionally direct. It explains the situation without exposing sensitive internal details to end users.
                </p>
            </div>
            @if (Model.ShowRequestId)
            {
                <div class="clay-panel-soft w-fit px-5 py-4 text-sm leading-7 text-clay-muted">
                    <strong class="text-clay-ink">Request ID:</strong> <code>@Model.RequestId</code>
                </div>
            }
        </div>
    </div>

    <div class="grid gap-5 lg:grid-cols-2">
        <section class="clay-panel-soft p-6">
            <h2 class="text-lg font-semibold text-clay-ink">What you can do next</h2>
            <ul class="mt-4 space-y-3 text-sm leading-7 text-clay-muted">
                <li class="clay-chip px-4 py-3">Return to the previous page and try again.</li>
                <li class="clay-chip px-4 py-3">If the issue persists, share the request ID with the support team.</li>
                <li class="clay-chip px-4 py-3">Do not refresh repeatedly if the request involved a form submission.</li>
            </ul>
        </section>

        <section class="clay-panel-soft p-6">
            <h2 class="text-lg font-semibold text-clay-ink">Development mode note</h2>
            <p class="mt-3 text-sm leading-7 text-clay-muted">
                Detailed exception information should stay in local development only. Production pages should not reveal stack traces or internal system data.
            </p>
        </section>
    </div>
</section>
