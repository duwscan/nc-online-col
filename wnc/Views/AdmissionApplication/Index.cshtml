@{
    ViewData["Title"] = "Admission Application Management - Ajax Demo";
}

<div class="container mt-4">
    <h2 class="mb-4">
        <i class="bi bi-file-earmark-text"></i> Admission Application Management
        <small class="text-muted fs-6">- Ajax Demo (Module 4)</small>
    </h2>

    <div class="card">
        <div class="card-header bg-purple text-white" style="background-color: #6f42c1;">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h5 class="mb-0">Applications List</h5>
                    <small>Hồ sơ đăng ký tuyển sinh - Ajax Integration</small>
                </div>
                <div class="col-md-6 text-end">
                    <button class="btn btn-light" id="btnRefresh">
                        <i class="bi bi-arrow-clockwise"></i> Refresh (XmlHttpRequest)
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label">Search</label>
                    <div class="input-group">
                        <input type="text" id="searchTerm" class="form-control"
                               placeholder="Code, Name, Email, CCCD..."
                               onkeypress="handleSearchKeypress(event)">
                        <button class="btn btn-outline-purple" type="button" onclick="searchApplications()" style="color: #6f42c1; border-color: #6f42c1;">
                            <i class="bi bi-search"></i> Search (Fetch)
                        </button>
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Status</label>
                    <select id="filterStatus" class="form-select" onchange="searchApplications()">
                        <option value="">All</option>
                        <option value="DRAFT">Nháp</option>
                        <option value="SUBMITTED">Đã nộp</option>
                        <option value="UNDER_REVIEW">Đang xét duyệt</option>
                        <option value="REQUIRED_SUPPLEMENT">Yêu cầu bổ sung</option>
                        <option value="RESUBMITTED">Đã bổ sung</option>
                        <option value="APPROVED">Đã duyệt</option>
                        <option value="REJECTED">Bị từ chối</option>
                        <option value="CANCELLED">Đã hủy</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Round/Program</label>
                    <select id="filterRoundProgram" class="form-select" onchange="searchApplications()">
                        <option value="">All Programs</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <label class="form-label">Page Size</label>
                    <select id="pageSize" class="form-select" onchange="changePageSize()">
                        <option value="5">5</option>
                        <option value="10" selected>10</option>
                        <option value="20">20</option>
                        <option value="50">50</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-purple w-100" onclick="refreshWithXHR()" style="background-color: #6f42c1; color: white;">
                        <i class="bi bi-arrow-clockwise"></i> Refresh (XHR)
                    </button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover table-bordered" id="applicationTable">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 12%">Code</th>
                            <th style="width: 18%">Candidate</th>
                            <th style="width: 15%">Program</th>
                            <th style="width: 12%">Round</th>
                            <th style="width: 10%">Status</th>
                            <th style="width: 8%">Docs</th>
                            <th style="width: 10%">Submitted</th>
                            <th style="width: 15%">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="applicationTableBody">
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <div class="spinner-border" style="color: #6f42c1;" role="status"></div>
                                <p class="mt-2">Loading data...</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="row align-items-center">
                <div class="col-md-6">
                    <p class="mb-0 text-muted">
                        Showing <span id="showingFrom">0</span> to <span id="showingTo">0</span> of <span id="totalCount">0</span> entries
                    </p>
                </div>
                <div class="col-md-6">
                    <nav aria-label="Application pagination">
                        <ul class="pagination justify-content-end mb-0" id="pagination">
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-code-slash"></i> Phương pháp Ajax trong bài thực hành</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-sm">
                    <thead class="table-primary">
                        <tr>
                            <th>Phương pháp</th>
                            <th>Chức năng</th>
                            <th>Ưu điểm</th>
                            <th>Nhược điểm</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="table-secondary">
                            <td><strong>XmlHttpRequest</strong></td>
                            <td><span class="badge bg-secondary">Refresh Data</span></td>
                            <td>Hỗ trợ tất cả trình duyệt, kiểm soát chi tiết</td>
                            <td>Code dài, callback phức tạp</td>
                        </tr>
                        <tr class="table-success">
                            <td><strong>Fetch API</strong></td>
                            <td><span class="badge bg-success">Search, Pagination</span></td>
                            <td>Syntax sạch, Promise-based, async/await</td>
                            <td>Không hỗ trợ IE cũ</td>
                        </tr>
                        <tr class="table-info">
                            <td><strong>jQuery AJAX</strong></td>
                            <td><span class="badge bg-primary">Update Status</span></td>
                            <td>Dễ dùng, global handlers, error handling</td>
                            <td>Phụ thuộc jQuery, kích thước lớn</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><i class="bi bi-diagram-3"></i> Luồng xử lý Ajax chi tiết</h5>
        </div>
        <div class="card-body">
            <div class="alert alert-primary mb-3">
                <h5 class="alert-heading"><i class="bi bi-info-circle"></i> Luồng: UI → JS → Controller → EF Core → DB → JSON → JS → DOM</h5>
            </div>

            <div class="row text-center">
                <div class="col">
                    <div class="p-3 border rounded bg-primary text-white">1. UI</div>
                    <i class="bi bi-arrow-down"></i>
                </div>
                <div class="col">
                    <div class="p-3 border rounded bg-success text-white">2. JavaScript</div>
                    <i class="bi bi-arrow-down"></i>
                </div>
                <div class="col">
                    <div class="p-3 border rounded bg-info text-white">3. Controller</div>
                    <i class="bi bi-arrow-down"></i>
                </div>
                <div class="col">
                    <div class="p-3 border rounded bg-warning text-dark">4. EF Core</div>
                    <i class="bi bi-arrow-down"></i>
                </div>
                <div class="col">
                    <div class="p-3 border rounded bg-danger text-white">5. Database</div>
                    <i class="bi bi-arrow-down"></i>
                </div>
                <div class="col">
                    <div class="p-3 border rounded bg-secondary text-white">6. JSON</div>
                    <i class="bi bi-arrow-down"></i>
                </div>
                <div class="col">
                    <div class="p-3 border rounded bg-success text-white">7. JS Render</div>
                    <i class="bi bi-arrow-down"></i>
                </div>
                <div class="col">
                    <div class="p-3 border rounded bg-primary text-white">8. DOM</div>
                </div>
            </div>

            <div class="alert alert-secondary mt-3 mb-0">
                <h6><i class="bi bi-code"></i> Code EF Core Pagination:</h6>
                <code class="text-danger">.Skip((page - 1) * pageSize).Take(pageSize)</code>
                <hr class="my-2">
                <h6><i class="bi bi-check-circle"></i> Controller trả JSON:</h6>
                <code class="text-success">return Json(result);</code>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="bi bi-lightning"></i> So sánh Request truyền thống vs Ajax</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="alert alert-secondary mb-0">
                        <h6 class="text-danger"><i class="bi bi-x-circle"></i> Request Truyền thống</h6>
                        <ol class="mb-0 mt-2">
                            <li>User click/submit</li>
                            <li>Browser gửi HTTP Request</li>
                            <li>Server xử lý + Render HTML</li>
                            <li class="text-danger"><strong>Server trả về TOÀN BỘ trang HTML</strong></li>
                            <li>Browser reload toàn bộ trang</li>
                        </ol>
                        <hr>
                        <strong>Nhược điểm:</strong> Chậm, tốn băng thông, mất trạng thái
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="alert alert-success mb-0">
                        <h6 class="text-success"><i class="bi bi-check-circle"></i> AJAX</h6>
                        <ol class="mb-0 mt-2">
                            <li>User tương tác (click/search)</li>
                            <li><strong>JS gửi AJAX Request (XHR/Fetch)</strong></li>
                            <li>Server xử lý + Trả JSON</li>
                            <li class="text-success"><strong>JS nhận JSON → Render DOM</strong></li>
                            <li>Chỉ cập nhật phần tử cần thiết</li>
                        </ol>
                        <hr>
                        <strong>Ưu điểm:</strong> Nhanh, mượt, trải nghiệm tốt
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="detailModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header" style="background-color: #6f42c1; color: white;">
                <h5 class="modal-title">Application Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="detailModalBody">
                <div class="text-center py-4">
                    <div class="spinner-border" style="color: #6f42c1;" role="status"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="statusModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title">Update Application Status</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="updateStatusAppId">
                <div class="mb-3">
                    <label class="form-label">New Status</label>
                    <select class="form-select" id="newStatus">
                    </select>
                </div>
                <div class="mb-3" id="reasonGroup" style="display: none;">
                    <label class="form-label">Reason (for Rejection)</label>
                    <textarea class="form-control" id="statusReason" rows="3"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning" id="btnUpdateStatus">
                    <i class="bi bi-check"></i> Update Status (jQuery AJAX)
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="historyModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title">Status History</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="historyModalBody">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admission-application-ajax.js"></script>
}
