@model wnc.Features.IdentityAccess.Users.UserDetailsViewModel

@{
    ViewData["Title"] = "User Details";
    var displayName = Model.Username ?? Model.Email ?? Model.PhoneNumber ?? Model.Id.ToString();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">User details</h1>
        <p class="text-muted mb-0">@displayName</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Username</dt>
                    <dd class="col-sm-8">@Model.Username</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>
                    <dt class="col-sm-4">Phone number</dt>
                    <dd class="col-sm-8">@Model.PhoneNumber</dd>
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">@Model.Status</dd>
                    <dt class="col-sm-4">Password hash</dt>
                    <dd class="col-sm-8"><code>@Model.PasswordHash</code></dd>
                    <dt class="col-sm-4">Email verified</dt>
                    <dd class="col-sm-8">@(Model.EmailVerifiedAt?.ToString("g") ?? "-")</dd>
                    <dt class="col-sm-4">Phone verified</dt>
                    <dd class="col-sm-8">@(Model.PhoneVerifiedAt?.ToString("g") ?? "-")</dd>
                    <dt class="col-sm-4">Last login</dt>
                    <dd class="col-sm-8">@(Model.LastLoginAt?.ToString("g") ?? "-")</dd>
                    <dt class="col-sm-4">Created</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("g")</dd>
                    <dt class="col-sm-4">Updated</dt>
                    <dd class="col-sm-8">@Model.UpdatedAt.ToString("g")</dd>
                    <dt class="col-sm-4">Deleted</dt>
                    <dd class="col-sm-8">@(Model.DeletedAt?.ToString("g") ?? "-")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h2 class="h5">Active roles</h2>
                @if (Model.Roles.Count == 0)
                {
                    <p class="text-muted mb-0">No active roles assigned.</p>
                }
                else
                {
                    <ul class="mb-0">
                        @foreach (var role in Model.Roles)
                        {
                            <li>@role</li>
                        }
                    </ul>
                }
            </div>
        </div>
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5">Recent auth logs</h2>
                @if (Model.RecentAuthLogs.Count == 0)
                {
                    <p class="text-muted mb-0">No log entries found.</p>
                }
                else
                {
                    <ul class="mb-0">
                        @foreach (var item in Model.RecentAuthLogs)
                        {
                            <li>@item</li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
