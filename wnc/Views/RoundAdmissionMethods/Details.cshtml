@model RoundAdmissionMethodDetailsViewModel
@{
    ViewData["Title"] = "Round Admission Method Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Round Admission Method Details</h1>
        <p class="text-muted mb-0">@Model.MethodName</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Round program</dt>
    <dd class="col-sm-9">@Model.RoundProgramName</dd>
    <dt class="col-sm-3">Method</dt>
    <dd class="col-sm-9">@Model.MethodName</dd>
    <dt class="col-sm-3">Combination code</dt>
    <dd class="col-sm-9">@Model.CombinationCode</dd>
    <dt class="col-sm-3">Minimum score</dt>
    <dd class="col-sm-9">@Model.MinimumScore</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
    <dt class="col-sm-3">Priority policy</dt>
    <dd class="col-sm-9">@Model.PriorityPolicy</dd>
    <dt class="col-sm-3">Calculation rule</dt>
    <dd class="col-sm-9">@Model.CalculationRule</dd>
    <dt class="col-sm-3">Created at</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToString("u")</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Delete this round admission method?');">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">Delete</button>
</form>
