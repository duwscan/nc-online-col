@model EnrollmentConfirmation
@{
    ViewData["Title"] = "Enrollment Confirmation Details";
}

<h1 class="h3 mb-4">Enrollment Confirmation Details</h1>

<dl class="row">
    <dt class="col-sm-3">Application</dt>
    <dd class="col-sm-9">@Model.Application.ApplicationCode</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.ConfirmationStatus</dd>
    <dt class="col-sm-3">Confirmed by candidate at</dt>
    <dd class="col-sm-9">@(Model.ConfirmedByCandidateAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</dd>
    <dt class="col-sm-3">Created at</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
    <dt class="col-sm-3">Updated at</dt>
    <dd class="col-sm-9">@Model.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
    <dt class="col-sm-3">Notes</dt>
    <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Notes) ? "-" : Model.Notes)</dd>
</dl>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
        <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Delete this record?');">Delete</button>
    </form>
</div>
