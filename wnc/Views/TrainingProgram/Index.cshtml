@{
    ViewData["Title"] = "Training Program Management - Ajax Demo";
}

<div class="container mt-4">
    <h2 class="mb-4">
        <i class="bi bi-mortarboard"></i> Training Program Management
        <small class="text-muted fs-6">- Ajax Demo (Module 2)</small>
    </h2>

    <div class="card">
        <div class="card-header bg-success text-white">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h5 class="mb-0">Training Programs List</h5>
                    <small>Quản lý chương trình đào tạo - Ajax Integration</small>
                </div>
                <div class="col-md-6 text-end">
                    <button class="btn btn-light" id="btnCreate">
                        <i class="bi bi-plus-circle"></i> Create (jQuery AJAX)
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label">Search</label>
                    <div class="input-group">
                        <input type="text" id="searchTerm" class="form-control"
                               placeholder="Code, Name or Description..."
                               onkeypress="handleSearchKeypress(event)">
                        <button class="btn btn-outline-success" type="button" onclick="searchPrograms()">
                            <i class="bi bi-search"></i> Search (Fetch)
                        </button>
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Education Type</label>
                    <select id="filterEducationType" class="form-select" onchange="searchPrograms()">
                        <option value="">All Types</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Status</label>
                    <select id="filterStatus" class="form-select" onchange="searchPrograms()">
                        <option value="">All</option>
                        <option value="ACTIVE">Active</option>
                        <option value="INACTIVE">Inactive</option>
                        <option value="DRAFT">Draft</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Page Size</label>
                    <select id="pageSize" class="form-select" onchange="changePageSize()">
                        <option value="5">5</option>
                        <option value="10" selected>10</option>
                        <option value="20">20</option>
                        <option value="50">50</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-success w-100" onclick="refreshWithXHR()">
                        <i class="bi bi-arrow-clockwise"></i> Refresh (XHR)
                    </button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover table-bordered" id="programTable">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 10%">Code</th>
                            <th style="width: 20%">Program Name</th>
                            <th style="width: 10%">Type</th>
                            <th style="width: 12%">Duration</th>
                            <th style="width: 12%">Tuition Fee</th>
                            <th style="width: 8%">Quota</th>
                            <th style="width: 8%">Majors</th>
                            <th style="width: 8%">Status</th>
                            <th style="width: 12%">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="programTableBody">
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                <div class="spinner-border text-success" role="status"></div>
                                <p class="mt-2">Loading data...</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="row align-items-center">
                <div class="col-md-6">
                    <p class="mb-0 text-muted">
                        Showing <span id="showingFrom">0</span> to <span id="showingTo">0</span> of <span id="totalCount">0</span> entries
                    </p>
                </div>
                <div class="col-md-6">
                    <nav aria-label="Program pagination">
                        <ul class="pagination justify-content-end mb-0" id="pagination">
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><i class="bi bi-diagram-3"></i> Phân tích luồng xử lý Ajax</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <h6 class="text-primary"><i class="bi bi-arrow-right-circle"></i> Request Truyền thống (Mỗi lần load lại trang)</h6>
                    <div class="border rounded p-3 bg-light">
                        <div class="d-flex flex-column gap-2">
                            <div class="d-flex align-items-center">
                                <span class="badge bg-secondary me-2">1</span>
                                <span>User click link/submit form</span>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-arrow-down mx-2 text-muted"></i>
                            </div>
                            <div class="d-flex align-items-center">
                                <span class="badge bg-secondary me-2">2</span>
                                <span>Browser gửi HTTP Request</span>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-arrow-down mx-2 text-muted"></i>
                            </div>
                            <div class="d-flex align-items-center">
                                <span class="badge bg-secondary me-2">3</span>
                                <span>Server xử lý + Render HTML</span>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-arrow-down mx-2 text-muted"></i>
                            </div>
                            <div class="d-flex align-items-center">
                                <span class="badge bg-danger me-2">4</span>
                                <strong>Server trả về TOÀN BỘ trang HTML</strong>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-arrow-down mx-2 text-muted"></i>
                            </div>
                            <div class="d-flex align-items-center">
                                <span class="badge bg-secondary me-2">5</span>
                                <span>Browser reload toàn bộ trang</span>
                            </div>
                        </div>
                        <hr>
                        <div class="alert alert-warning mb-0 py-2">
                            <i class="bi bi-exclamation-triangle"></i> <strong>Nhược điểm:</strong> Chậm, tốn băng thông, mất trạng thái
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <h6 class="text-success"><i class="bi bi-lightning-charge"></i> AJAX (Không reload trang)</h6>
                    <div class="border rounded p-3 bg-light">
                        <div class="d-flex flex-column gap-2">
                            <div class="d-flex align-items-center">
                                <span class="badge bg-success me-2">1</span>
                                <span>User tương tác (click/search)</span>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-arrow-down mx-2 text-success"></i>
                            </div>
                            <div class="d-flex align-items-center">
                                <span class="badge bg-success me-2">2</span>
                                <span><strong>JS gửi AJAX Request (XHR/Fetch)</strong></span>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-arrow-down mx-2 text-success"></i>
                            </div>
                            <div class="d-flex align-items-center">
                                <span class="badge bg-success me-2">3</span>
                                <span>Server xử lý + Trả JSON</span>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-arrow-down mx-2 text-success"></i>
                            </div>
                            <div class="d-flex align-items-center">
                                <span class="badge bg-warning me-2">4</span>
                                <span><strong>JS nhận JSON → Render DOM</strong></span>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-arrow-down mx-2 text-success"></i>
                            </div>
                            <div class="d-flex align-items-center">
                                <span class="badge bg-success me-2">5</span>
                                <span>Chỉ cập nhật phần tử cần thiết</span>
                            </div>
                        </div>
                        <hr>
                        <div class="alert alert-success mb-0 py-2">
                            <i class="bi bi-check-circle"></i> <strong>Ưu điểm:</strong> Nhanh, mượt, trải nghiệm tốt
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-code-slash"></i> Code minh họa 3 phương pháp Ajax</h5>
        </div>
        <div class="card-body">
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#xhr-code" type="button">
                        <i class="bi bi-braces"></i> XmlHttpRequest
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#fetch-code" type="button">
                        <i class="bi bi-lightning"></i> Fetch API
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#jquery-code" type="button">
                        <i class="bi bi-bootstrap"></i> jQuery AJAX
                    </button>
                </li>
            </ul>
            <div class="tab-content mt-3">
                <div class="tab-pane fade show active" id="xhr-code">
                    <div class="alert alert-secondary">
                        <pre class="mb-0"><code>// 1. XmlHttpRequest - Dùng cho Refresh
const xhr = new XMLHttpRequest();
xhr.open('GET', '/Controller/Action', true);
xhr.setRequestHeader('Content-Type', 'application/json');

xhr.onreadystatechange = function() {
    if (xhr.readyState === 4 && xhr.status === 200) {
        const data = JSON.parse(xhr.responseText);
        // Render data vào DOM
    }
};
xhr.send();</code></pre>
                    </div>
                </div>
                <div class="tab-pane fade" id="fetch-code">
                    <div class="alert alert-success">
                        <pre class="mb-0"><code>// 2. Fetch API - Dùng cho Search/Pagination
const response = await fetch('/Controller/Action?page=1');
const data = await response.json();
// Render data vào DOM

// POST với Fetch
const res = await fetch('/Controller/Create', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
});</code></pre>
                    </div>
                </div>
                <div class="tab-pane fade" id="jquery-code">
                    <div class="alert alert-info">
                        <pre class="mb-0"><code>// 3. jQuery AJAX - Dùng cho CRUD
$.ajax({
    url: '/Controller/Create',
    method: 'POST',
    contentType: 'application/json',
    data: JSON.stringify(data),
    success: function(response) {
        // Xử lý thành công
    },
    error: function(xhr) {
        // Xử lý lỗi
    }
});</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">Ajax Methods Comparison</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm table-bordered mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th>Method</th>
                            <th>Used For</th>
                            <th>Code Example</th>
                            <th>Browser Support</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>XmlHttpRequest</strong></td>
                            <td><span class="badge bg-secondary">Refresh Data</span></td>
                            <td><small>Verbose, callback-based</small></td>
                            <td><span class="badge bg-success">All browsers</span></td>
                        </tr>
                        <tr>
                            <td><strong>Fetch API</strong></td>
                            <td><span class="badge bg-success">Search, Pagination</span></td>
                            <td><small>Clean, Promise-based</small></td>
                            <td><span class="badge bg-warning">Modern browsers</span></td>
                        </tr>
                        <tr>
                            <td><strong>jQuery AJAX</strong></td>
                            <td><span class="badge bg-primary">Create, Edit, Delete</span></td>
                            <td><small>Easy, global handlers</small></td>
                            <td><span class="badge bg-success">All browsers</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><i class="bi bi-diagram-3"></i> Chi tiết luồng UI → JS → Controller → EF Core → DB → JSON → JS → DOM</h5>
        </div>
        <div class="card-body">
            <div class="row text-center">
                <div class="col">
                    <div class="p-3 border rounded bg-primary text-white">
                        <i class="bi bi-display"></i>
                        <h6>1. UI</h6>
                        <small>User click Search</small>
                    </div>
                    <i class="bi bi-arrow-down my-2"></i>
                </div>
                <div class="col">
                    <div class="p-3 border rounded bg-success text-white">
                        <i class="bi bi-filetype-js"></i>
                        <h6>2. JavaScript</h6>
                        <small>fetch() gọi API</small>
                    </div>
                    <i class="bi bi-arrow-down my-2"></i>
                </div>
                <div class="col">
                    <div class="p-3 border rounded bg-info text-white">
                        <i class="bi bi-git"></i>
                        <h6>3. Controller</h6>
                        <small>Nhận request, validate</small>
                    </div>
                    <i class="bi bi-arrow-down my-2"></i>
                </div>
                <div class="col">
                    <div class="p-3 border rounded bg-warning text-dark">
                        <i class="bi bi-database"></i>
                        <h6>4. EF Core</h6>
                        <small>Skip/Take pagination</small>
                    </div>
                    <i class="bi bi-arrow-down my-2"></i>
                </div>
                <div class="col">
                    <div class="p-3 border rounded bg-danger text-white">
                        <i class="bi bi-server"></i>
                        <h6>5. Database</h6>
                        <small>SQL query execution</small>
                    </div>
                    <i class="bi bi-arrow-down my-2"></i>
                </div>
                <div class="col">
                    <div class="p-3 border rounded bg-secondary text-white">
                        <i class="bi bi-braces"></i>
                        <h6>6. JSON</h6>
                        <small>Serialize response</small>
                    </div>
                    <i class="bi bi-arrow-down my-2"></i>
                </div>
                <div class="col">
                    <div class="p-3 border rounded bg-success text-white">
                        <i class="bi bi-filetype-js"></i>
                        <h6>7. JS Render</h6>
                        <small>Xử lý JSON data</small>
                    </div>
                    <i class="bi bi-arrow-down my-2"></i>
                </div>
                <div class="col">
                    <div class="p-3 border rounded bg-primary text-white">
                        <i class="bi bi-display"></i>
                        <h6>8. DOM</h6>
                        <small>Cập nhật bảng</small>
                    </div>
                </div>
            </div>
            <hr>
            <div class="alert alert-secondary mb-0">
                <strong>EF Core Skip/Take Pagination:</strong>
                <code class="ms-2">.Skip((page - 1) * pageSize).Take(pageSize)</code>
                <hr class="my-2">
                <strong>Controller trả JSON:</strong>
                <code class="ms-2">return Json(result)</code>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="programModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="modalTitle">Create Training Program</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalBody">
                <div class="text-center py-4">
                    <div class="spinner-border text-success" role="status"></div>
                </div>
            </div>
            <div class="modal-footer" id="modalFooter">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-success" id="btnSave">
                    <i class="bi bi-save"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Delete Program</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle"></i>
                    Are you sure you want to delete this program?
                </div>
                <input type="hidden" id="deleteProgramId">
                <p class="program-name fw-bold" id="deleteProgramName"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="btnConfirmDelete">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="detailModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title">Program Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="detailModalBody">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/training-program-ajax.js"></script>
}
