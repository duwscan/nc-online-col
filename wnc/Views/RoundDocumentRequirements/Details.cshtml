@model RoundDocumentRequirementDetailsViewModel
@{
    ViewData["Title"] = "Round Document Requirement Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Round Document Requirement Details</h1>
        <p class="text-muted mb-0">@Model.DocumentTypeName</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Round program</dt>
    <dd class="col-sm-9">@Model.RoundProgramName</dd>
    <dt class="col-sm-3">Document type</dt>
    <dd class="col-sm-9">@Model.DocumentTypeName</dd>
    <dt class="col-sm-3">Is required</dt>
    <dd class="col-sm-9">@(Model.IsRequired ? "Yes" : "No")</dd>
    <dt class="col-sm-3">Requires notarization</dt>
    <dd class="col-sm-9">@(Model.RequiresNotarization ? "Yes" : "No")</dd>
    <dt class="col-sm-3">Requires original copy</dt>
    <dd class="col-sm-9">@(Model.RequiresOriginalCopy ? "Yes" : "No")</dd>
    <dt class="col-sm-3">Max files</dt>
    <dd class="col-sm-9">@Model.MaxFiles</dd>
    <dt class="col-sm-3">Notes</dt>
    <dd class="col-sm-9">@Model.Notes</dd>
    <dt class="col-sm-3">Created at</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToString("u")</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Delete this round document requirement?');">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">Delete</button>
</form>
