@model wnc.Features.Admin.Rounds.ViewModels.EditRoundViewModel
@{
    ViewData["Title"] = "Cập nhật đợt xét tuyển";
}

<section class="mx-auto max-w-4xl space-y-6">
    <form method="post" action="/admin/rounds/edit/@Model.Id" class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/60">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <input type="hidden" name="addProgramIds" id="addProgramIds" value="" />
        <input type="hidden" name="removeRoundProgramIds" id="removeRoundProgramIds" value="" />

        <div class="flex flex-col gap-2 border-b border-slate-200 pb-5">
            <p class="text-sm font-medium text-blue-600">Quản lý tuyển sinh</p>
            <h3 class="text-2xl font-semibold text-slate-900">Cập nhật đợt xét tuyển</h3>
            <p class="text-sm text-slate-500">Điều chỉnh thông tin đợt xét tuyển để đồng bộ với kế hoạch triển khai thực tế.</p>
        </div>

        <div asp-validation-summary="ModelOnly" class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>

        <div class="grid gap-5 md:grid-cols-2">
            <div class="space-y-1">
                <label asp-for="RoundCode" class="block text-sm font-medium text-slate-700"></label>
                <input asp-for="RoundCode" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm text-slate-900 focus:border-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-400" />
                <span asp-validation-for="RoundCode" class="text-sm text-red-600"></span>
            </div>

            <div class="space-y-1">
                <label asp-for="Status" class="block text-sm font-medium text-slate-700"></label>
                <select asp-for="Status" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm text-slate-900 focus:border-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-400">
                    @foreach (var status in Model.AvailableStatuses)
                    {
                        <option value="@status">@status</option>
                    }
                </select>
                <span asp-validation-for="Status" class="text-sm text-red-600"></span>
            </div>

            <div class="space-y-1 md:col-span-2">
                <label asp-for="RoundName" class="block text-sm font-medium text-slate-700"></label>
                <input asp-for="RoundName" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm text-slate-900 focus:border-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-400" />
                <span asp-validation-for="RoundName" class="text-sm text-red-600"></span>
            </div>

            <div class="space-y-1">
                <label asp-for="AdmissionYear" class="block text-sm font-medium text-slate-700"></label>
                <input asp-for="AdmissionYear" type="number" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm text-slate-900 focus:border-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-400" />
                <span asp-validation-for="AdmissionYear" class="text-sm text-red-600"></span>
            </div>

            <div class="space-y-1">
                <label asp-for="AllowEnrollmentConfirmation" class="block text-sm font-medium text-slate-700"></label>
                <label class="flex items-center gap-3 rounded-2xl border border-slate-200 px-4 py-3 text-sm text-slate-700">
                    <input asp-for="AllowEnrollmentConfirmation" class="h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500" />
                    <span>Cho phép thí sinh xác nhận nhập học trong đợt này</span>
                </label>
                <span asp-validation-for="AllowEnrollmentConfirmation" class="text-sm text-red-600"></span>
            </div>

            <div class="space-y-1">
                <label asp-for="StartAt" class="block text-sm font-medium text-slate-700"></label>
                <input asp-for="StartAt" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm text-slate-900 focus:border-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-400" />
                <span asp-validation-for="StartAt" class="text-sm text-red-600"></span>
            </div>

            <div class="space-y-1">
                <label asp-for="EndAt" class="block text-sm font-medium text-slate-700"></label>
                <input asp-for="EndAt" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm text-slate-900 focus:border-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-400" />
                <span asp-validation-for="EndAt" class="text-sm text-red-600"></span>
            </div>

            <div class="space-y-1 md:col-span-2">
                <label asp-for="Notes" class="block text-sm font-medium text-slate-700"></label>
                <textarea asp-for="Notes" rows="4" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm text-slate-900 focus:border-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-400"></textarea>
                <span asp-validation-for="Notes" class="text-sm text-red-600"></span>
            </div>
        </div>

        <div class="flex flex-col gap-3 border-t border-slate-200 pt-5 sm:flex-row sm:justify-end">
            <a href="/admin/rounds" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-600 transition hover:bg-slate-50 hover:text-slate-900">Hủy</a>
            <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-slate-900 px-4 py-3 text-sm font-semibold text-white transition hover:bg-slate-800">Lưu thay đổi</button>
        </div>
    </form>

    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/60">
        <div class="mb-4 flex items-center justify-between">
            <div>
                <h3 class="text-lg font-semibold text-slate-900">Chương trình trong đợt xét tuyển</h3>
                <p class="mt-1 text-sm text-slate-500">Quản lý các chương trình đào tạo được áp dụng cho đợt này.</p>
            </div>
        </div>

        @if (Model.AssignedPrograms.Count > 0)
        {
            <div class="mb-4 overflow-x-auto">
                <table id="programsTable" class="min-w-full divide-y divide-slate-200 text-left text-sm">
                    <thead class="bg-slate-50 text-slate-500">
                        <tr>
                            <th class="px-4 py-3 font-medium">Mã</th>
                            <th class="px-4 py-3 font-medium">Tên chương trình</th>
                            <th class="px-4 py-3 font-medium">Loại hình</th>
                            <th class="px-4 py-3 font-medium">Chỉ tiêu</th>
                            <th class="px-4 py-3 font-medium">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="programsTableBody" class="divide-y divide-slate-100">
                        @foreach (var program in Model.AssignedPrograms)
                        {
                            <tr>
                                <td class="px-4 py-3 font-medium text-slate-900">@program.ProgramCode</td>
                                <td class="px-4 py-3">@program.ProgramName</td>
                                <td class="px-4 py-3">@program.EducationType</td>
                                <td class="px-4 py-3">@program.Quota</td>
                                <td class="px-4 py-3">
                                    <button type="button" onclick="removeProgram('@program.Id')" class="rounded-xl border border-rose-200 px-3 py-1.5 text-xs font-semibold text-rose-600 transition hover:bg-rose-50 hover:text-rose-700">Xóa</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div id="emptyProgramsMessage" class="mb-4 text-sm text-slate-500">
                <p>Chưa có chương trình nào được thêm vào đợt xét tuyển này.</p>
            </div>
            <table id="programsTable" class="min-w-full divide-y divide-slate-200 text-left text-sm hidden">
                <thead class="bg-slate-50 text-slate-500">
                    <tr>
                        <th class="px-4 py-3 font-medium">Mã</th>
                        <th class="px-4 py-3 font-medium">Tên chương trình</th>
                        <th class="px-4 py-3 font-medium">Loại hình</th>
                        <th class="px-4 py-3 font-medium">Chỉ tiêu</th>
                        <th class="px-4 py-3 font-medium">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="programsTableBody" class="divide-y divide-slate-100"></tbody>
            </table>
        }

        <div class="flex flex-col gap-4 sm:flex-row sm:items-end">
            <div class="flex-1 space-y-1">
                <label for="programSelect" class="block text-sm font-medium text-slate-700">Thêm chương trình</label>
                <select id="programSelect" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm text-slate-900 focus:border-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-400">
                    <option value="">-- Chọn chương trình --</option>
                    @foreach (var program in Model.AvailablePrograms)
                    {
                        var isAssigned = Model.AssignedPrograms.Any(ap => ap.ProgramId == program.Id);
                        if (!isAssigned)
                        {
                            <option value="@program.Id">@program.ProgramCode - @program.ProgramName (@program.EducationType)</option>
                        }
                    }
                </select>
            </div>
            <button type="button" onclick="addProgram()" class="inline-flex items-center justify-center rounded-2xl bg-blue-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-blue-700">Thêm</button>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let addedProgramIds = [];
        let removedRoundProgramIds = [];

        function addProgram() {
            const select = document.getElementById('programSelect');
            const programId = select.value;
            if (!programId) return;

            if (addedProgramIds.includes(programId)) {
                alert('Chương trình này đã được thêm.');
                return;
            }

            addedProgramIds.push(programId);
            document.getElementById('addProgramIds').value = addedProgramIds.join(',');

            // Show table and hide empty message if first program
            const emptyMessage = document.getElementById('emptyProgramsMessage');
            const table = document.getElementById('programsTable');
            if (emptyMessage) emptyMessage.style.display = 'none';
            if (table) table.classList.remove('hidden');

            const option = select.options[select.selectedIndex];
            const textParts = option.text.split(' - ');
            const code = textParts[0] || '';
            const nameAndType = textParts[1] || '';
            const typeMatch = nameAndType.match(/\(([^)]+)\)/);
            const name = nameAndType.replace(/\([^)]*\)/, '').trim();
            const type = typeMatch ? typeMatch[1] : '';

            const tbody = document.getElementById('programsTableBody');
            const row = document.createElement('tr');
            row.id = 'new-program-' + programId;
            row.innerHTML = `
                <td class="px-4 py-3 font-medium text-slate-900">${escapeHtml(code)}</td>
                <td class="px-4 py-3">${escapeHtml(name)}</td>
                <td class="px-4 py-3">${escapeHtml(type)}</td>
                <td class="px-4 py-3">-</td>
                <td class="px-4 py-3">
                    <button type="button" onclick="undoAddProgram('${programId}')" class="rounded-xl border border-rose-200 px-3 py-1.5 text-xs font-semibold text-rose-600 transition hover:bg-rose-50 hover:text-rose-700">Hủy</button>
                </td>
            `;
            if (tbody) {
                tbody.appendChild(row);
            }
            select.remove(select.selectedIndex);
        }

        function undoAddProgram(programId) {
            addedProgramIds = addedProgramIds.filter(id => id !== programId);
            document.getElementById('addProgramIds').value = addedProgramIds.join(',');

            const row = document.getElementById('new-program-' + programId);
            if (row) row.remove();

            const select = document.getElementById('programSelect');
            const option = document.createElement('option');
            option.value = programId;
            option.text = programId; // Use programId as fallback since we can't easily get the text back
            select.appendChild(option);
        }

        function removeProgram(roundProgramId) {
            if (!removedRoundProgramIds.includes(roundProgramId)) {
                removedRoundProgramIds.push(roundProgramId);
                document.getElementById('removeRoundProgramIds').value = removedRoundProgramIds.join(',');
            }
            event.target.closest('tr').style.opacity = '0.5';
            event.target.closest('tr').style.pointerEvents = 'none';
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
    </script>
}
