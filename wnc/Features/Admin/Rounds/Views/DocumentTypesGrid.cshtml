@model List<DocumentType>
@{
    ViewData["Title"] = "Loại giấy tờ - Lưới";
}

<div class="space-y-6">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/60">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <p class="text-sm font-medium text-blue-600">Admissions</p>
                <h3 class="mt-1 text-2xl font-semibold text-slate-900">Loại giấy tờ</h3>
                <p class="mt-2 text-sm text-slate-500">Quản lý danh mục giấy tờ (CCCD, Học bạ, Bằng tốt nghiệp, ...)</p>
            </div>
            <a href="/admin/document-types-grid/create" class="inline-flex items-center justify-center rounded-2xl bg-blue-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-blue-700">
                Thêm loại giấy tờ
            </a>
        </div>
        
        <form method="get" action="/admin/document-types-grid">
            <input placeholder="tên giấy tờ" name="tenGiayTo"/>
            <input placeholder="mô tả" name="moTa"/>
            
            <button type="submit">find</button>
            <hr/>
            <a href="/admin/document-types-grid">exit</a>
        </form>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="rounded-xl bg-green-50 p-4 text-sm text-green-700">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="rounded-xl bg-red-50 p-4 text-sm text-red-700">@TempData["ErrorMessage"]</div>
    }

    @if (Model.Count == 0)
    {
        <div class="rounded-3xl border border-slate-200 bg-white p-12 text-center shadow-sm shadow-slate-200/60">
            <p class="text-sm text-slate-500">Không có loại giấy tờ nào.</p>
        </div>
    }
    else
    {
        <!-- Responsive Grid: 1 column on mobile, 3 columns on lg screens -->
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
            @foreach (var dt in Model)
            {
                <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/60 transition hover:shadow-md hover:shadow-slate-200">
                    <div class="space-y-4">
                        <!-- Header with Code Badge -->
                        <div class="flex items-start justify-between gap-3">
                            <div class="flex-1">
                                <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Mã</p>
                                <p class="mt-1 font-mono text-sm font-semibold text-slate-900">@dt.DocumentCode</p>
                            </div>
                            @if (dt.Status == "ACTIVE")
                            {
                                <span class="rounded-full bg-green-50 px-3 py-1 text-xs font-semibold text-green-700">ACTIVE</span>
                            }
                            else
                            {
                                <span class="rounded-full bg-slate-200 px-3 py-1 text-xs font-semibold text-slate-600">@dt.Status</span>
                            }
                        </div>

                        <!-- Document Name -->
                        <div>
                            <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Tên giấy tờ</p>
                            <p class="mt-1 text-base font-semibold text-slate-900">@dt.DocumentName</p>
                        </div>

                        <!-- Description -->
                        <div>
                            <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Mô tả</p>
                            <p class="mt-1 line-clamp-2 text-sm text-slate-600">@(string.IsNullOrWhiteSpace(dt.Description) ? "Không có mô tả" : dt.Description)</p>
                        </div>

                        <!-- Actions -->
                        <div class="flex gap-2 border-t border-slate-100 pt-4">
                            <a href="/admin/document-types-grid/edit/@dt.Id" class="flex-1 rounded-lg border border-slate-200 px-3 py-2 text-center text-xs font-semibold text-slate-700 transition hover:bg-blue-50 hover:border-blue-300 hover:text-blue-700">
                                Sửa
                            </a>
                            <form method="post" action="/admin/document-types-grid/delete/@dt.Id" onsubmit="return confirm('Bạn có chắc muốn xóa?');" class="flex-1">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="w-full rounded-lg border border-rose-200 px-3 py-2 text-xs font-semibold text-rose-600 transition hover:bg-rose-50 hover:border-rose-300 hover:text-rose-700">
                                    Xóa
                                </button>
                            </form>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</div>
