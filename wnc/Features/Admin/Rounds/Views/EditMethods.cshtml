@model wnc.Features.Admin.Rounds.ViewModels.EditRoundMethodsViewModel
@{
    ViewData["Title"] = $"Phương thức xét tuyển - {Model.RoundName}";
}

<div class="mx-auto max-w-6xl space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Phương thức xét tuyển</h1>
            <p class="mt-1 text-sm text-gray-500">@Model.RoundCode - @Model.RoundName</p>
        </div>
        <a href="/admin/rounds" class="rounded-lg bg-gray-100 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-200">
            Quay lại
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="rounded-lg bg-green-50 p-4 text-sm text-green-700">
            @TempData["SuccessMessage"]
        </div>
    }

    <form method="post" action="/admin/rounds/@Model.RoundId/methods">
        @Html.AntiForgeryToken()

        <div class="space-y-6">
            @for (int i = 0; i < Model.Programs.Count; i++)
            {
                var program = Model.Programs[i];
                <div class="rounded-xl border border-gray-200 bg-white p-6">
                    <h2 class="text-lg font-semibold text-gray-900">
                        @program.ProgramName
                        @if (!string.IsNullOrEmpty(program.MajorName))
                        {
                            <span class="text-gray-500">- @program.MajorName</span>
                        }
                    </h2>

                    <div class="mt-4 space-y-3">
                        @for (int j = 0; j < program.AvailableMethods.Count; j++)
                        {
                            var method = program.AvailableMethods[j];
                            var existingMethod = program.Methods.FirstOrDefault(m => m.MethodId == method.Id);
                            var isChecked = existingMethod != null;

                            <div class="flex items-center gap-4 rounded-lg border border-gray-100 bg-gray-50 p-4">
                                <input type="checkbox"
                                       name="method_@(method.Id)"
                                       value="@method.Id"
                                       @(isChecked ? "checked" : "")
                                       class="h-5 w-5 rounded border-gray-300 text-blue-600" />

                                <div class="flex-1">
                                    <div class="font-medium text-gray-900">@method.MethodName</div>
                                    <div class="text-xs text-gray-500">@method.MethodCode</div>
                                </div>

                                <div class="flex items-center gap-2">
                                    <label class="text-sm text-gray-600">Điểm chuẩn:</label>
                                    <input type="number"
                                           name="minscore_@(method.Id)"
                                           value="@(isChecked && existingMethod!.MinimumScore.HasValue ? existingMethod.MinimumScore.Value.ToString() : "")"
                                           step="0.01"
                                           min="0"
                                           placeholder="0.00"
                                           class="w-24 rounded-lg border border-gray-300 px-3 py-1.5 text-sm" />
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="mt-6 flex justify-end">
            <button type="submit" class="rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white hover:bg-blue-700">
                Lưu cấu hình
            </button>
        </div>
    </form>
</div>
