@model wnc.Features.Admin.Rounds.ViewModels.EditRoundDocumentsViewModel
@{
    ViewData["Title"] = $"Cấu hình hồ sơ - {Model.RoundName}";
}

<div class="mx-auto max-w-6xl space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Cấu hình hồ sơ</h1>
            <p class="mt-1 text-sm text-gray-500">@Model.RoundCode - @Model.RoundName</p>
        </div>
        <a href="/admin/rounds" class="rounded-lg bg-gray-100 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-200">
            Quay lại
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="rounded-lg bg-green-50 p-4 text-sm text-green-700">
            @TempData["SuccessMessage"]
        </div>
    }

    <form method="post" action="/admin/rounds/@Model.RoundId/documents">
        @Html.AntiForgeryToken()

        <div class="space-y-6">
            @foreach (var program in Model.Programs)
            {
                <div class="rounded-xl border border-gray-200 bg-white p-6">
                    <h2 class="text-lg font-semibold text-gray-900">
                        @program.ProgramName
                        @if (!string.IsNullOrEmpty(program.MajorName))
                        {
                            <span class="text-gray-500">- @program.MajorName</span>
                        }
                    </h2>

                    <div class="mt-4 overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead>
                                <tr class="border-b border-gray-100 text-left">
                                    <th class="pb-3 font-medium text-gray-700">Giấy tờ</th>
                                    <th class="pb-3 text-center font-medium text-gray-700">Bắt buộc</th>
                                    <th class="pb-3 text-center font-medium text-gray-700">Công chứng</th>
                                    <th class="pb-3 text-center font-medium text-gray-700">Bản gốc</th>
                                    <th class="pb-3 text-center font-medium text-gray-700">Số file</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-50">
                                @foreach (var docType in program.AvailableDocumentTypes)
                                {
                                    var requirement = program.Requirements.FirstOrDefault(r => r.DocumentTypeId == docType.Id);
                                    var isChecked = requirement != null;
                                    <tr>
                                        <td class="py-3">
                                            <div class="font-medium text-gray-900">@docType.DocumentName</div>
                                            <div class="text-xs text-gray-500">@docType.DocumentCode</div>
                                            <input type="hidden" name="doc_@(docType.Id)" value="@docType.Id" />
                                        </td>
                                        <td class="py-3 text-center">
                                            <input type="checkbox"
                                                   name="required_@(program.Id)_@(docType.Id)"
                                                   value="true"
                                                   @(isChecked && requirement!.IsRequired ? "checked" : "")
                                                   class="h-4 w-4 rounded border-gray-300 text-blue-600" />
                                        </td>
                                        <td class="py-3 text-center">
                                            <input type="checkbox"
                                                   name="notarization_@(program.Id)_@(docType.Id)"
                                                   value="true"
                                                   @(isChecked && requirement!.RequiresNotarization ? "checked" : "")
                                                   class="h-4 w-4 rounded border-gray-300 text-blue-600" />
                                        </td>
                                        <td class="py-3 text-center">
                                            <input type="checkbox"
                                                   name="original_@(program.Id)_@(docType.Id)"
                                                   value="true"
                                                   @(isChecked && requirement!.RequiresOriginalCopy ? "checked" : "")
                                                   class="h-4 w-4 rounded border-gray-300 text-blue-600" />
                                        </td>
                                        <td class="py-3 text-center">
                                            <input type="number"
                                                   name="maxfiles_@(program.Id)_@(docType.Id)"
                                                   value="@(isChecked ? requirement!.MaxFiles : 1)"
                                                   min="1"
                                                   max="10"
                                                   class="w-16 rounded-lg border border-gray-300 px-2 py-1 text-center" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>

        <div class="mt-6 flex justify-end">
            <button type="submit" class="rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white hover:bg-blue-700">
                Lưu cấu hình
            </button>
        </div>
    </form>
</div>
