@model DocumentType
@{
    ViewData["Title"] = "Sửa loại giấy tờ";
    bool isAdmin = (bool)ViewBag.IsAdmin;
    bool isDisabled = (bool)ViewBag.IsDisabled;
    bool canEdit = isAdmin && !isDisabled;
}

<div class="mx-auto max-w-2xl space-y-6">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/60">
        <div class="flex items-center justify-between">
            <h1 class="text-xl font-semibold text-slate-900">Sửa loại giấy tờ</h1>
            @if (!canEdit)
            {
                <span class="rounded-lg bg-yellow-50 px-3 py-1 text-sm font-medium text-yellow-800">
                    @if (isDisabled)
                    {
                        <span>🔒 Bị khóa</span>
                    }
                    else
                    {
                        <span>👁️ Chỉ xem</span>
                    }
                </span>
            }
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="mt-4 rounded-xl bg-red-50 p-4 text-sm text-red-700">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p>@error.ErrorMessage</p>
                }
            </div>
        }

        <form method="post" action="/admin/document-types/edit/@Model.Id" class="mt-6 space-y-4">
            @Html.AntiForgeryToken()

            <div>
                <label class="block text-sm font-medium text-slate-700">Mã giấy tờ</label>
                <input value="@Model.DocumentCode" class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-500" readonly />
                <p class="mt-1 text-xs text-slate-400">Mã giấy tờ không thể thay đổi.</p>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Tên giấy tờ</label>
                <input name="DocumentName" id="DocumentName" value="@Model.DocumentName" class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-3" placeholder="VD: Căn cước công dân" @(canEdit ? "" : "disabled") />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Mô tả</label>
                <textarea name="Description" rows="3" class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-3" @(canEdit ? "" : "disabled")>@Model.Description</textarea>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Trạng thái</label>
                <select name="Status" class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-3" @(canEdit ? "" : "disabled")>
                    <option value="ACTIVE" selected="@(Model.Status == "ACTIVE")">ACTIVE</option>
                    <option value="INACTIVE" selected="@(Model.Status == "INACTIVE")">INACTIVE</option>
                </select>
            </div>

            <div class="flex gap-3 pt-4">
                @if (canEdit)
                {
                    <button type="submit" class="rounded-xl bg-blue-600 px-6 py-3 text-sm font-semibold text-white hover:bg-blue-700">Lưu</button>
                }
                else
                {
                    <button type="submit" class="rounded-xl bg-gray-400 px-6 py-3 text-sm font-semibold text-white cursor-not-allowed" disabled>Lưu</button>
                }
                <a href="/admin/document-types" class="rounded-xl border border-slate-300 px-6 py-3 text-sm font-medium text-slate-700 hover:bg-slate-50">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function generateSlug(name) {
            return name.toLowerCase()
                .replace(/\s+/g, '-')
                .replace(/[^a-z0-9\-]/g, '')
                .replace(/-+/g, '-')
                .replace(/^-|-$/g, '');
        }

        const nameInput = document.getElementById('DocumentName');
        if (nameInput && !nameInput.disabled) {
            nameInput.addEventListener('input', function(e) {
                document.querySelector('input[name="DocumentCode"]').value = generateSlug(e.target.value);
            });
        }
    </script>
}
