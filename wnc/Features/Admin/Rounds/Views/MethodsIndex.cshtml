@model List<AdmissionMethod>
@{
    ViewData["Title"] = "Phương thức xét tuyển";
}

<div class="space-y-6">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/60">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <p class="text-sm font-medium text-blue-600">Admissions</p>
                <h3 class="mt-1 text-2xl font-semibold text-slate-900">Phương thức xét tuyển</h3>
                <p class="mt-2 text-sm text-slate-500">Quản lý các phương thức xét tuyển (HOC_BA, DIEM_THI, TUYEN_THANG, ...)</p>
            </div>
            <a href="/admin/methods/create" class="inline-flex items-center justify-center rounded-2xl bg-blue-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-blue-700">
                Thêm phương thức
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="rounded-xl bg-green-50 p-4 text-sm text-green-700">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="rounded-xl bg-red-50 p-4 text-sm text-red-700">@TempData["ErrorMessage"]</div>
    }

    <article class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm shadow-slate-200/60">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
                <thead class="bg-slate-50 text-slate-500">
                    <tr>
                        <th class="px-6 py-4 font-medium">Mã</th>
                        <th class="px-6 py-4 font-medium">Tên phương thức</th>
                        <th class="px-6 py-4 font-medium">Mô tả</th>
                        <th class="px-6 py-4 font-medium">Trạng thái</th>
                        <th class="px-6 py-4 font-medium">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 bg-white text-slate-700">
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center text-sm text-slate-500">Không có phương thức xét tuyển nào.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var method in Model)
                        {
                            <tr>
                                <td class="px-6 py-4">
                                    <span class="rounded-lg bg-slate-100 px-2 py-1 font-mono text-sm font-semibold text-slate-700">@method.MethodCode</span>
                                </td>
                                <td class="px-6 py-4 font-medium text-slate-900">@method.MethodName</td>
                                <td class="px-6 py-4 text-slate-500">@method.Description</td>
                                <td class="px-6 py-4">
                                    @if (method.Status == "ACTIVE")
                                    {
                                        <span class="rounded-full bg-green-50 px-2.5 py-1 text-xs font-semibold text-green-700">ACTIVE</span>
                                    }
                                    else
                                    {
                                        <span class="rounded-full bg-slate-200 px-2.5 py-1 text-xs font-semibold text-slate-600">@method.Status</span>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex gap-2">
                                        <a href="/admin/methods/edit/@method.Id" class="rounded-xl border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-50 hover:text-slate-900">Sửa</a>
                                        <form method="post" action="/admin/methods/delete/@method.Id" onsubmit="return confirm('Bạn có chắc muốn xóa?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="rounded-xl border border-rose-200 px-3 py-2 text-xs font-semibold text-rose-600 transition hover:bg-rose-50 hover:text-rose-700">Xóa</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </article>
</div>
