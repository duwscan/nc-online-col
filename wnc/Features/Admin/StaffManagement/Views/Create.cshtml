@model wnc.Features.Admin.StaffManagement.ViewModels.CreateStaffViewModel
@{
    ViewData["Title"] = "Create Staff";
}

<section class="mx-auto max-w-4xl">
    <form method="post" action="/admin/staff/create" class="space-y-6 rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/60">
        @Html.AntiForgeryToken()

        <div class="flex flex-col gap-2 border-b border-slate-200 pb-5">
            <p class="text-sm font-medium text-blue-600">Users Management</p>
            <h3 class="text-2xl font-semibold text-slate-900">Create staff account</h3>
            <p class="text-sm text-slate-500">Provision an internal user account and assign one or more admin portal roles.</p>
        </div>

        <div asp-validation-summary="ModelOnly" class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>

        <div class="grid gap-5 md:grid-cols-2">
            <div class="space-y-1">
                <label asp-for="Username" class="block text-sm font-medium text-slate-700"></label>
                <input asp-for="Username" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm text-slate-900 focus:border-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-400" />
                <span asp-validation-for="Username" class="text-sm text-red-600"></span>
            </div>

            <div class="space-y-1">
                <label asp-for="Status" class="block text-sm font-medium text-slate-700"></label>
                <select asp-for="Status" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm text-slate-900 focus:border-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-400">
                    @foreach (var status in Model.AvailableStatuses)
                    {
                        <option value="@status">@status</option>
                    }
                </select>
                <span asp-validation-for="Status" class="text-sm text-red-600"></span>
            </div>

            <div class="space-y-1">
                <label asp-for="Email" class="block text-sm font-medium text-slate-700"></label>
                <input asp-for="Email" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm text-slate-900 focus:border-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-400" />
                <span asp-validation-for="Email" class="text-sm text-red-600"></span>
            </div>

            <div class="space-y-1">
                <label asp-for="PhoneNumber" class="block text-sm font-medium text-slate-700"></label>
                <input asp-for="PhoneNumber" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm text-slate-900 focus:border-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-400" />
                <span asp-validation-for="PhoneNumber" class="text-sm text-red-600"></span>
            </div>

            <div class="space-y-1 md:col-span-2">
                <label asp-for="Password" class="block text-sm font-medium text-slate-700"></label>
                <input asp-for="Password" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm text-slate-900 focus:border-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-400" />
                <p class="text-xs text-slate-500">Use at least 8 characters for the initial sign-in password.</p>
                <span asp-validation-for="Password" class="text-sm text-red-600"></span>
            </div>
        </div>

        <div class="space-y-4 rounded-3xl border border-slate-200 bg-slate-50 p-5">
            <div>
                <h4 class="text-base font-semibold text-slate-900">Role assignment</h4>
                <p class="mt-1 text-sm text-slate-500">Select all staff roles that this account should receive.</p>
            </div>

            <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-3">
                @foreach (var role in Model.AvailableRoles)
                {
                    <label class="flex items-start gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-4 text-sm text-slate-700">
                        @if (role.IsSelected)
                        {
                            <input type="checkbox" name="SelectedRoleCodes" value="@role.Code" checked class="mt-1 h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500" />
                        }
                        else
                        {
                            <input type="checkbox" name="SelectedRoleCodes" value="@role.Code" class="mt-1 h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500" />
                        }
                        <span>
                            <span class="block font-semibold text-slate-900">@role.Name</span>
                            @if (!string.IsNullOrWhiteSpace(role.Description))
                            {
                                <span class="mt-1 block text-xs text-slate-500">@role.Description</span>
                            }
                        </span>
                    </label>
                }
            </div>

            <span asp-validation-for="SelectedRoleCodes" class="text-sm text-red-600"></span>
        </div>

        <div class="flex flex-col gap-3 border-t border-slate-200 pt-5 sm:flex-row sm:justify-end">
            <a href="/admin/staff" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-600 transition hover:bg-slate-50 hover:text-slate-900">Cancel</a>
            <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-slate-900 px-4 py-3 text-sm font-semibold text-white transition hover:bg-slate-800">Create staff account</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
