@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var displayName = ViewData["DisplayName"] as string ?? "Admin";
    var studentCount = (int)(ViewData["StudentCount"] ?? 0);
    var currentRound = ViewData["CurrentRound"] as wnc.Models.AdmissionRound;
}

<div class="space-y-6">
    <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <h1 class="text-2xl font-semibold text-slate-900">Xin chào, @displayName</h1>
        <p class="mt-1 text-sm text-slate-500">Chào mừng bạn quay trở lại trang quản trị</p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-slate-500">Số thí sinh</p>
                    <p class="mt-2 text-3xl font-semibold text-slate-900">@studentCount</p>
                </div>
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-blue-50">
                    <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                    </svg>
                </div>
            </div>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-slate-500">Đợt xét tuyển hiện tại</p>
                    @if (currentRound != null)
                    {
                        <p class="mt-2 text-3xl font-semibold text-slate-900">@currentRound.RoundName</p>
                        <p class="mt-1 text-xs text-slate-400">@currentRound.RoundCode</p>
                    }
                    else
                    {
                        <p class="mt-2 text-xl font-semibold text-slate-400">Không có đợt</p>
                    }
                </div>
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-green-50">
                    <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                    </svg>
                </div>
            </div>
        </div>
    </div>
</div>
