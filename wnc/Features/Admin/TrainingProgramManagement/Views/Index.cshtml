@model wnc.Features.Admin.TrainingProgramManagement.ViewModels.TrainingProgramListViewModel
@{
    ViewData["Title"] = "Chương trình đào tạo";
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="mb-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700">
        @successMessage
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="mb-6 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-700">
        @errorMessage
    </div>
}

<section class="space-y-6">
    <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/60">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <p class="text-sm font-medium text-blue-600">Quản lý tuyển sinh</p>
                <h3 class="mt-1 text-2xl font-semibold text-slate-900">Chương trình đào tạo</h3>
                <p class="mt-2 text-sm text-slate-500">Theo dõi danh mục chương trình, chỉ tiêu, học phí và trạng thái hiển thị trong cổng tuyển sinh.</p>
            </div>
            <a href="/admin/programs/create" class="inline-flex items-center justify-center rounded-2xl bg-slate-900 px-4 py-3 text-sm font-semibold text-white transition hover:bg-slate-800">
                Tạo chương trình
            </a>
        </div>

        <form method="get" action="/admin/programs" class="mt-6 grid gap-4 lg:grid-cols-[minmax(0,1.7fr)_minmax(180px,1fr)_minmax(180px,1fr)_auto]">
            <div class="space-y-1">
                <label for="searchTerm" class="block text-sm font-medium text-slate-700">Tìm kiếm</label>
                <input id="searchTerm" name="searchTerm" value="@Model.SearchTerm" placeholder="Mã hoặc tên chương trình" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-400" />
            </div>

            <div class="space-y-1">
                <label for="educationType" class="block text-sm font-medium text-slate-700">Hệ đào tạo</label>
                <select id="educationType" name="educationType" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm text-slate-900 focus:border-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-400">
                    <option value="">Tất cả hệ đào tạo</option>
                    @foreach (var item in Model.AvailableEducationTypes)
                    {
                        if (string.Equals(Model.EducationType, item.Value, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@item.Value" selected>@item.Label</option>
                        }
                        else
                        {
                            <option value="@item.Value">@item.Label</option>
                        }
                    }
                </select>
            </div>

            <div class="space-y-1">
                <label for="status" class="block text-sm font-medium text-slate-700">Trạng thái</label>
                <select id="status" name="status" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm text-slate-900 focus:border-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-400">
                    <option value="">Tất cả trạng thái</option>
                    @foreach (var status in Model.AvailableStatuses)
                    {
                        if (string.Equals(Model.Status, status, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@status" selected>@status</option>
                        }
                        else
                        {
                            <option value="@status">@status</option>
                        }
                    }
                </select>
            </div>

            <div class="flex items-end gap-2 lg:justify-end">
                <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-3 py-2 text-sm font-medium text-white transition hover:bg-blue-700">Áp dụng</button>
                <a href="/admin/programs" class="inline-flex items-center justify-center rounded-xl border border-slate-200 px-3 py-2 text-sm font-medium text-slate-600 transition hover:bg-slate-50 hover:text-slate-900">Đặt lại</a>
            </div>
        </form>
    </article>

    <article class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm shadow-slate-200/60">
        <div class="flex flex-col gap-3 border-b border-slate-200 px-6 py-5 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h3 class="text-lg font-semibold text-slate-900">Danh sách chương trình</h3>
                <p class="mt-1 text-sm text-slate-500">Hiển thị @Model.StartItem-@Model.EndItem của @Model.TotalItems chương trình.</p>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
                <thead class="bg-slate-50 text-slate-500">
                    <tr>
                        <th scope="col" class="px-6 py-4 font-medium">Mã chương trình</th>
                        <th scope="col" class="px-6 py-4 font-medium">Tên chương trình</th>
                        <th scope="col" class="px-6 py-4 font-medium">Hệ đào tạo</th>
                        <th scope="col" class="px-6 py-4 font-medium">Học phí</th>
                        <th scope="col" class="px-6 py-4 font-medium">Chỉ tiêu</th>
                        <th scope="col" class="px-6 py-4 font-medium">Trạng thái</th>
                        <th scope="col" class="px-6 py-4 font-medium">Thứ tự</th>
                        <th scope="col" class="px-6 py-4 font-medium">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 bg-white text-slate-700">
                    @if (Model.Programs.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="px-6 py-12 text-center text-sm text-slate-500">Không tìm thấy chương trình đào tạo phù hợp.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var program in Model.Programs)
                        {
                            <tr>
                                <td class="px-6 py-4 font-medium text-slate-900">@program.ProgramCode</td>
                                <td class="px-6 py-4">@program.ProgramName</td>
                                <td class="px-6 py-4">@program.EducationTypeLabel</td>
                                <td class="px-6 py-4">@(program.TuitionFee.HasValue ? string.Format("{0:N0} đ", program.TuitionFee.Value) : "-")</td>
                                <td class="px-6 py-4">@program.Quota</td>
                                <td class="px-6 py-4">
                                    @if (string.Equals(program.Status, "ACTIVE", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-emerald-700">Đang hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-600">Ngừng hoạt động</span>
                                    }
                                </td>
                                <td class="px-6 py-4">@program.DisplayOrder</td>
                                <td class="px-6 py-4">
                                    <div class="flex flex-wrap gap-2">
                                        <a href="/admin/programs/edit/@program.Id" class="inline-flex items-center rounded-xl border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-50 hover:text-slate-900">Sửa</a>
                                        <form method="post" action="/admin/programs/toggle-status/@program.Id">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                                            <button type="submit" class="inline-flex items-center rounded-xl border border-blue-200 px-3 py-2 text-xs font-semibold text-blue-600 transition hover:bg-blue-50 hover:text-blue-700">
                                                @(string.Equals(program.Status, "ACTIVE", StringComparison.OrdinalIgnoreCase) ? "Ngừng kích hoạt" : "Kích hoạt")
                                            </button>
                                        </form>
                                        <form method="post" action="/admin/programs/delete/@program.Id" class="inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa chương trình này?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="inline-flex items-center rounded-xl border border-rose-200 px-3 py-2 text-xs font-semibold text-rose-700 transition hover:bg-rose-50 hover:text-rose-900">Xóa</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="flex flex-col gap-3 border-t border-slate-200 px-6 py-4 sm:flex-row sm:items-center sm:justify-between">
                <p class="text-sm text-slate-500">Trang @Model.Page của @Model.TotalPages</p>
                <div class="flex gap-2">
                    <a href="/admin/programs?searchTerm=@Model.SearchTerm&educationType=@Model.EducationType&status=@Model.Status&page=@Math.Max(1, Model.Page - 1)" class="@(Model.Page <= 1 ? "pointer-events-none rounded-xl border border-slate-200 px-4 py-2 text-sm font-medium text-slate-300" : "rounded-xl border border-slate-200 px-4 py-2 text-sm font-medium text-slate-600 transition hover:bg-slate-50 hover:text-slate-900")">Trước</a>
                    <a href="/admin/programs?searchTerm=@Model.SearchTerm&educationType=@Model.EducationType&status=@Model.Status&page=@Math.Min(Model.TotalPages, Model.Page + 1)" class="@(Model.Page >= Model.TotalPages ? "pointer-events-none rounded-xl border border-slate-200 px-4 py-2 text-sm font-medium text-slate-300" : "rounded-xl border border-slate-200 px-4 py-2 text-sm font-medium text-slate-600 transition hover:bg-slate-50 hover:text-slate-900")">Sau</a>
                </div>
            </div>
        }
    </article>
</section>
